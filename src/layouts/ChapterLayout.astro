---
import BaseLayout from './BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Badge from '../components/Badge/Badge.astro';
import Footer from '../components/Footer/Footer.astro';
import Discussion from '../components/Discussion/Discussion.astro';
import ProgressTracker from '../components/ProgressTracker/ProgressTracker.tsx';
import ChapterNav from '../components/ChapterNav/ChapterNav.tsx';
import ChapterFooter from '../components/ChapterFooter/ChapterFooter.tsx';
import type { Lang } from '../lib/i18n';
import ReferencesList from '../components/ReferencesList/ReferencesList.astro';
import { ui, getProjectAlternateLinks } from '../lib/i18n';
import { CHAPTERS, resolveChapterReferences } from '../data/chapters';

interface Props {
  chapterNumber: number;
  lang: Lang;
}

const { chapterNumber, lang } = Astro.props;
const chapter = CHAPTERS.find((ch) => ch.number === chapterNumber)!;
const labels = ui[lang].chapters;
const alternateLinks = getProjectAlternateLinks();
const references = resolveChapterReferences(chapter, lang);
const badgeVariant = chapter.isReference ? 'blue' : 'coral';
const badgeText = chapter.isReference
  ? labels.reference
  : labels.chapterLabel(chapterNumber);
const gitReminder =
  lang === 'pt-BR'
    ? {
        title: 'Antes de sair deste capítulo',
        body: 'Salve o que foi feito até aqui no Git antes de avançar. Isso ajuda você a manter progresso, histórico e pontos seguros de retorno.',
        note: 'Troque a mensagem do commit por um resumo curto e real do que mudou neste capítulo.',
        commitMessage: '[resuma o que foi feito neste capitulo]',
      }
    : {
        title: 'Before leaving this chapter',
        body: 'Save your work in Git before moving on. This gives you progress checkpoints, history, and safe rollback points.',
        note: 'Replace the commit message with a short, real summary of what changed in this chapter.',
        commitMessage: '[summarize what changed in this chapter]',
      };
---

<BaseLayout
  title={`${chapter.title[lang]} | ${ui[lang].project.title} | AI-Native Engineering`}
  description={chapter.description[lang]}
  lang={lang}
  alternateLinks={alternateLinks}
>
  <ProgressTracker
    client:idle
    sessionSlug={`${lang}:projeto-${chapter.id}`}
    ariaLabel={ui[lang].progressLabel}
  />
  <main id="main-content" class="chapter-page">
    <SectionBlock as="header" padding="xl">
      <Badge variant={badgeVariant}>{badgeText}</Badge>
      <h1 class="chapter-title">{chapter.title[lang]}</h1>
      <p class="chapter-summary">{chapter.description[lang]}</p>
    </SectionBlock>

    <div class="chapter-body">
      <aside class="chapter-sidebar">
        <ChapterNav client:idle currentChapter={chapterNumber} lang={lang} />
      </aside>
      <article class="session-content">
        <slot />
        <div class="git-reminder">
          <strong>{gitReminder.title}</strong>
          <p>{gitReminder.body}</p>
          <pre><code>{`git add .
git commit -m "${gitReminder.commitMessage}"
git push`}</code></pre>
          <p class="git-reminder-note">{gitReminder.note}</p>
        </div>
        <ChapterFooter
          client:visible
          chapterNumber={chapterNumber}
          lang={lang}
        />
      </article>
    </div>

    {
      references.length > 0 && (
        <SectionBlock padding="xl" alt>
          <ReferencesList references={references} lang={lang} />
        </SectionBlock>
      )
    }

    <Discussion
      lang={lang}
      slug={`projeto-${chapter.id}`}
      title={chapter.title[lang]}
    />

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .chapter-title {
    margin-top: var(--space-md);
    max-width: 20ch;
  }

  .chapter-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-md);
    max-width: 68ch;
    color: var(--color-text-muted);
  }

  .chapter-body {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--space-md);
    padding-block: var(--space-xl);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    min-width: 0;
  }

  .chapter-sidebar {
    display: none;
    min-width: 0;
  }

  .session-content {
    min-width: 0;
  }

  .session-content :global(h2) {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    scroll-margin-top: var(--space-xl);
  }

  .session-content :global(h3) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }

  .session-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .session-content :global(ul),
  .session-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .session-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .session-content :global(astro-island) {
    display: block;
    max-width: 100%;
    min-width: 0;
    margin-block: var(--space-xl) var(--space-2xl);
  }

  .session-content :global(blockquote) {
    border-left: 4px solid var(--color-accent-1);
    padding-left: var(--space-lg);
    margin-block: var(--space-lg);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .session-content :global(hr) {
    border: none;
    border-top: var(--border-thin);
    margin-block: var(--space-2xl);
  }

  .session-content :global(h2:first-child) {
    margin-top: 0;
  }

  .session-content :global(.checkpoint) {
    border: var(--border-thick);
    border-left: 6px solid var(--color-accent-3);
    background-color: var(--color-bg-alt);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    margin-block: var(--space-lg);
  }

  .session-content :global(.checkpoint strong) {
    font-family: var(--font-heading);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .session-content :global(.prompt-example) {
    border: var(--border-thin);
    background-color: var(--color-bg-alt);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    margin-block: var(--space-md);
  }

  .session-content :global(.prompt-good) {
    border-left: 6px solid var(--color-accent-3);
  }

  .session-content :global(.prompt-bad) {
    border-left: 6px solid var(--color-accent-4);
  }

  .session-content :global(.prompt-example strong) {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .session-content :global(.git-reminder) {
    border: var(--border-thick);
    border-left: 6px solid var(--color-accent-1);
    background-color: var(--color-bg-alt);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-xl);
  }

  .session-content :global(.git-reminder strong) {
    font-family: var(--font-heading);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .session-content :global(.git-reminder p:last-child) {
    margin-bottom: 0;
  }

  .session-content :global(.git-reminder-note) {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (min-width: 1024px) {
    .chapter-body {
      grid-template-columns: 220px minmax(0, 1fr);
      padding-inline: var(--space-xl);
      padding-block: var(--space-3xl);
      gap: var(--space-2xl);
    }

    .chapter-sidebar {
      display: block;
    }

    .session-content :global(h2) {
      margin-top: var(--space-4xl);
      margin-bottom: var(--space-lg);
    }

    .session-content :global(h3) {
      margin-top: var(--space-3xl);
      margin-bottom: var(--space-md);
    }

    .session-content :global(p),
    .session-content :global(ul),
    .session-content :global(ol) {
      margin-bottom: var(--space-lg);
    }
  }
</style>
