---
import BaseLayout from './BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Badge from '../components/Badge/Badge.astro';
import SectionNav from '../components/SectionNav/SectionNav.astro';
import ReferencesList from '../components/ReferencesList/ReferencesList.astro';
import NextSessionCTA from '../components/NextSessionCTA/NextSessionCTA.astro';
import Footer from '../components/Footer/Footer.astro';
import Discussion from '../components/Discussion/Discussion.astro';
import ProgressTracker from '../components/ProgressTracker/ProgressTracker.tsx';
import Breadcrumbs from '../components/Breadcrumbs/Breadcrumbs.astro';
import type { Lang } from '../lib/i18n';
import { languages, ui, getHomeHref } from '../lib/i18n';
import { getSessionAlternateLinks } from '../data/sessions';

interface Reference {
  id: string;
  title: string;
  url: string;
  type: 'artigo' | 'documentacao' | 'talk' | 'video' | 'pesquisa';
  source: string;
  category: string;
  priority?: number;
}

interface Props {
  title: string;
  slug: string;
  lang: Lang;
  translationKey: string;
  summary: string;
  readingTime: number;
  level: 'beginner' | 'intermediate' | 'advanced';
  heroLabel: string;
  updatedAt: Date;
  tags: string[];
  order: number;
  references: Reference[];
  nextSession: { title: string; slug: string; heroLabel: string } | null;
}

const {
  title,
  slug,
  lang,
  translationKey,
  summary,
  readingTime,
  level,
  heroLabel,
  updatedAt,
  references,
  nextSession,
} = Astro.props;

const labels = ui[lang];
const alternateLinks = getSessionAlternateLinks(translationKey);

const breadcrumbItems = [
  { label: labels.breadcrumb.home, href: getHomeHref(lang) },
  {
    label: labels.breadcrumb.sessions,
    href: `${getHomeHref(lang)}${labels.breadcrumb.sessionsAnchor}`,
  },
  { label: title },
];
const formattedUpdatedAt = updatedAt.toLocaleDateString(
  languages[lang].dateLocale,
  {
    month: 'long',
    year: 'numeric',
  },
);
---

<BaseLayout
  title={`${title} | AI-Native Engineers`}
  description={summary}
  lang={lang}
  alternateLinks={alternateLinks}
>
  <ProgressTracker
    client:idle
    sessionSlug={`${lang}:${slug}`}
    ariaLabel={labels.progressLabel}
  />
  <main id="main-content" class="session-page">
    <!-- article header -->
    <SectionBlock as="header" padding="xl">
      <Breadcrumbs items={breadcrumbItems} lang={lang} />
      <span class="kicker">{heroLabel}</span>
      <h1 class="session-title" transition:name="session-hero-title">
        {title}
      </h1>
      <div class="session-meta">
        <Badge size="sm">{labels.levels[level]}</Badge>
        <Badge size="sm">{labels.readingMinutes(readingTime)}</Badge>
        <time class="session-date" datetime={updatedAt.toISOString()}>
          {labels.updatedAt}
          {formattedUpdatedAt}
        </time>
      </div>
    </SectionBlock>

    <!-- summary -->
    <SectionBlock padding="lg" alt id="resumo">
      <h2>{labels.summaryHeading}</h2>
      <p class="summary-text">{summary}</p>
    </SectionBlock>

    <!-- body: sidebar + content -->
    <div class="session-body">
      <aside class="session-sidebar">
        <SectionNav lang={lang} />
      </aside>
      <article class="session-content">
        <slot />
      </article>
    </div>

    <!-- references -->
    {
      references.length > 0 && (
        <SectionBlock padding="xl" alt id="referencias">
          <ReferencesList references={references} lang={lang} />
        </SectionBlock>
      )
    }

    <!-- next session -->
    {
      nextSession ? (
        <NextSessionCTA
          lang={lang}
          nextTitle={nextSession.title}
          nextSlug={nextSession.slug}
          nextHeroLabel={nextSession.heroLabel}
        />
      ) : (
        <NextSessionCTA lang={lang} isLast />
      )
    }

    <Discussion lang={lang} slug={slug} title={title} />

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .session-title {
    margin-top: var(--space-md);
    max-width: 16ch;
  }

  .session-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding-block: var(--space-md);
    border-top: var(--line);
    border-bottom: var(--line);
  }

  .session-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .summary-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lede);
    line-height: var(--leading-snug);
    margin-top: var(--space-md);
    max-width: 60ch;
  }

  .session-body {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding-inline: var(--space-md);
    padding-block: var(--space-xl);
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-xl);
    min-width: 0;
  }

  .session-sidebar {
    display: none;
    min-width: 0;
  }

  .session-content {
    min-width: 0;
  }

  /* prose styles for MDX slot content */
  .session-content :global(h2) {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    scroll-margin-top: var(--space-xl);
  }

  .session-content :global(h3) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }

  .session-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .session-content :global(ul),
  .session-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .session-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .session-content :global(astro-island) {
    display: block;
    max-width: 100%;
    min-width: 0;
    margin-block: var(--space-xl) var(--space-2xl);
    content-visibility: auto;
    contain-intrinsic-size: auto 400px;
  }

  .session-content :global(figure),
  .session-content :global(pre) {
    content-visibility: auto;
    contain-intrinsic-size: auto 320px;
  }

  /* pull quote — the serif moment with a 2px signal rule */
  .session-content :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-lg);
    margin-block: var(--space-xl);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  .session-content :global(hr) {
    border: none;
    border-top: var(--line);
    margin-block: var(--space-2xl);
  }

  .session-content :global(img) {
    border: var(--line);
    border-radius: var(--radius-sm);
  }

  /* editorial table — hairline rules, no fills */
  .session-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    border-top: var(--line);
    border-bottom: var(--line);
    margin-block: var(--space-lg);
    display: block;
    overflow-x: auto;
  }

  .session-content :global(thead) {
    display: table;
    width: 100%;
    table-layout: fixed;
  }

  .session-content :global(tbody) {
    display: table;
    width: 100%;
    table-layout: fixed;
  }

  .session-content :global(th) {
    background: transparent;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-ink);
  }

  .session-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: var(--line);
    font-size: var(--text-sm);
    vertical-align: top;
  }

  .session-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .session-content :global(h2:first-child) {
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .session-body {
      grid-template-columns: 220px minmax(0, 1fr);
      padding-inline: var(--space-xl);
      padding-block: var(--space-3xl);
      gap: var(--space-2xl);
    }

    .session-sidebar {
      display: block;
    }

    .session-content :global(h2) {
      margin-top: var(--space-4xl);
      margin-bottom: var(--space-lg);
    }

    .session-content :global(h3) {
      margin-top: var(--space-3xl);
      margin-bottom: var(--space-md);
    }

    .session-content :global(p),
    .session-content :global(ul),
    .session-content :global(ol) {
      margin-bottom: var(--space-lg);
    }
  }
</style>
