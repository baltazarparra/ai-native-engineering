---
import BaseLayout from './BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Footer from '../components/Footer/Footer.astro';
import Discussion from '../components/Discussion/Discussion.astro';
import HarnessChapterTabs from '../components/harness/HarnessChapterTabs';
import HarnessChapterPager from '../components/harness/HarnessChapterPager';
import HarnessChapterIntro from '../components/harness/HarnessChapterIntro';
import HarnessShareBar from '../components/harness/HarnessShareBar';
import Breadcrumbs from '../components/Breadcrumbs/Breadcrumbs.astro';
import type { AlternateLink, Lang } from '../lib/i18n';
import { ui, getHomeHref, getHarnessOverviewHref } from '../lib/i18n';
import type { HarnessChapterId } from '../data/harness-chapters';
import { HARNESS_SERIES } from '../data/harness-chapters';

interface Props {
  lang: Lang;
  activeTab: 'overview' | HarnessChapterId;
  title: string;
  description: string;
  alternateLinks: AlternateLink[];
  discussionSlug: string;
  discussionTitle: string;
  heroBadge?: string;
  heroTitle: string;
  heroSummary?: string;
}

const {
  lang,
  activeTab,
  title,
  description,
  alternateLinks,
  discussionSlug,
  discussionTitle,
  heroBadge,
  heroTitle,
  heroSummary,
} = Astro.props;

const shareUrl = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbItems =
  activeTab === 'overview'
    ? [
        { label: ui[lang].breadcrumb.home, href: getHomeHref(lang) },
        { label: HARNESS_SERIES.title[lang] },
      ]
    : [
        { label: ui[lang].breadcrumb.home, href: getHomeHref(lang) },
        {
          label: HARNESS_SERIES.title[lang],
          href: getHarnessOverviewHref(lang),
        },
        { label: heroTitle },
      ];
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  alternateLinks={alternateLinks}
  ogImage="/og-harness.png"
>
  <main id="main-content" class="harness-page">
    <SectionBlock as="header" padding="xl">
      <Breadcrumbs items={breadcrumbItems} lang={lang} />
      {heroBadge ? <span class="kicker">{heroBadge}</span> : null}
      <h1 class="harness-page-title">{heroTitle}</h1>
      {heroSummary ? <p class="harness-page-summary">{heroSummary}</p> : null}
      <HarnessShareBar
        client:visible
        url={shareUrl}
        title={heroTitle}
        lang={lang}
      />
    </SectionBlock>

    <HarnessChapterTabs client:load lang={lang} activeTab={activeTab} />

    {
      activeTab !== 'overview' && (
        <HarnessChapterIntro
          client:visible
          lang={lang}
          chapterId={activeTab}
        />
      )
    }

    <slot />

    {
      activeTab !== 'overview' && (
        <HarnessChapterPager
          client:visible
          lang={lang}
          chapterId={activeTab}
        />
      )
    }

    <Discussion lang={lang} slug={discussionSlug} title={discussionTitle} />

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style is:global>
  @import '../styles/harness-chapter.css';

  .harness-page-title {
    margin-top: var(--space-md);
    max-width: 14ch;
  }

  .harness-page-summary {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lede);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    margin-top: var(--space-md);
    max-width: 58ch;
  }
</style>
