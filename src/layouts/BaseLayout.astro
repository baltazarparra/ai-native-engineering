---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/SiteHeader/SiteHeader.astro';
import type { AlternateLink, Lang } from '../lib/i18n';
import {
  defaultLang,
  languages,
  languagePreferenceStorageKey,
  supportedLangs,
  ui,
} from '../lib/i18n';
import { themeStorageKey } from '../lib/theme';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: Lang;
  alternateLinks?: AlternateLink[];
  showHeader?: boolean;
}

const {
  title,
  lang = 'pt-BR',
  description = ui[lang].siteDescription,
  ogImage,
  noindex = false,
  alternateLinks = [],
  showHeader = true,
} = Astro.props;

const ogImageUrl =
  ogImage ||
  new URL(`${import.meta.env.BASE_URL}og-default.png`, Astro.site).href;

const absoluteAlternateLinks = alternateLinks.map((link) => ({
  ...link,
  href: new URL(link.href, Astro.site).href,
}));

const languageRedirectAlternates = Object.fromEntries(
  alternateLinks
    .filter((link): link is AlternateLink & { lang: Lang } =>
      supportedLangs.includes(link.lang as Lang),
    )
    .map((link) => [link.lang, link.href]),
) as Partial<Record<Lang, string>>;

const languageRedirectConfig = {
  currentLang: lang,
  defaultLang,
  storageKey: languagePreferenceStorageKey,
  alternateHrefs: languageRedirectAlternates,
};

const languageRedirectScript = `
(function () {
  var config = ${JSON.stringify(languageRedirectConfig)};
  var storedLang = null;

  try {
    storedLang = window.localStorage.getItem(config.storageKey);
  } catch (error) {
    storedLang = null;
  }

  function isAvailable(lang) {
    return Boolean(lang && config.alternateHrefs[lang]);
  }

  function getBrowserLang() {
    var browserLangs =
      navigator.languages && navigator.languages.length
        ? navigator.languages
        : [navigator.language || ''];

    for (var i = 0; i < browserLangs.length; i += 1) {
      var browserLang = String(browserLangs[i] || '')
        .toLowerCase()
        .replace('_', '-');

      if (browserLang === 'pt' || browserLang.indexOf('pt-') === 0) {
        return 'pt-BR';
      }

      if (browserLang === 'en' || browserLang.indexOf('en-') === 0) {
        return 'en';
      }
    }

    return config.defaultLang;
  }

  function rememberChoice(event) {
    var target = event.target;
    var link =
      target && target.closest
        ? target.closest('[data-language-choice]')
        : null;

    if (!link) return;

    try {
      window.localStorage.setItem(
        config.storageKey,
        link.getAttribute('data-language-choice')
      );
    } catch (error) {}
  }

  if (!window.__aiNativeLanguageChoiceListener) {
    window.__aiNativeLanguageChoiceListener = rememberChoice;
    document.addEventListener('click', rememberChoice);
  }

  var targetLang = isAvailable(storedLang) ? storedLang : getBrowserLang();
  var hasStoredPreference = isAvailable(storedLang);

  if (!isAvailable(targetLang) || targetLang === config.currentLang) return;
  if (config.currentLang !== config.defaultLang && !hasStoredPreference) return;

  var targetUrl = new URL(config.alternateHrefs[targetLang], window.location.href);
  targetUrl.hash = window.location.hash;

  if (targetUrl.href !== window.location.href) {
    window.location.replace(targetUrl.href);
  }
})();
`;

const themeInitScript = `
(function () {
  var key = ${JSON.stringify(themeStorageKey)};
  var stored = null;
  try {
    stored = window.localStorage.getItem(key);
  } catch (error) {
    stored = null;
  }
  /* Light is always the default. Dark mode only engages when the user opts in
     via the ThemeToggle, which writes 'dark' to localStorage. OS-level
     prefers-color-scheme is intentionally ignored. */
  var theme = stored === 'dark' ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', theme);
})();
`;
---

<!doctype html>
<html lang={languages[lang].htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={themeInitScript} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={languages[lang].locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.href} />
    {
      absoluteAlternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.lang} href={link.href} />
      ))
    }
    {
      Object.keys(languageRedirectAlternates).length > 1 && (
        <script is:inline data-astro-rerun set:html={languageRedirectScript} />
      )
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=JetBrains+Mono&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{ui[lang].skipToContent}</a>
    {showHeader && <SiteHeader lang={lang} alternateLinks={alternateLinks} />}
    <slot />
  </body>
</html>
