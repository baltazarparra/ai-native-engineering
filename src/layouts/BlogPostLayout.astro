---
import BaseLayout from './BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Badge from '../components/Badge/Badge.astro';
import Footer from '../components/Footer/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs/Breadcrumbs.astro';
import type { AlternateLink, Lang } from '../lib/i18n';
import { languages, ui, getHomeHref, getBlogHref } from '../lib/i18n';

interface Props {
  title: string;
  slug: string;
  lang: Lang;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  tags: string[];
  alternateLinks?: AlternateLink[];
}

const {
  title,
  lang,
  description,
  publishedAt,
  updatedAt,
  author,
  tags,
  alternateLinks = [],
} = Astro.props;

const labels = ui[lang];
const dateOptions: Intl.DateTimeFormatOptions = {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
};

const formattedPublishedAt = publishedAt.toLocaleDateString(
  languages[lang].dateLocale,
  dateOptions,
);
const formattedUpdatedAt = updatedAt?.toLocaleDateString(
  languages[lang].dateLocale,
  dateOptions,
);

const breadcrumbItems = [
  { label: labels.breadcrumb.home, href: getHomeHref(lang) },
  { label: labels.blog.breadcrumb, href: getBlogHref(lang) },
  { label: title },
];
---

<BaseLayout
  title={`${title} | AI-Native Engineers`}
  description={description}
  lang={lang}
  ogType="article"
  articlePublishedTime={publishedAt.toISOString()}
  articleModifiedTime={updatedAt?.toISOString()}
  articleAuthor={author}
  alternateLinks={alternateLinks}
>
  <main id="main-content" class="blog-page">
    <SectionBlock as="header" padding="xl">
      <Breadcrumbs items={breadcrumbItems} lang={lang} />
      <span class="kicker">{labels.blog.title}</span>
      <h1 class="blog-title">{title}</h1>
      <p class="blog-description">{description}</p>
      <div class="blog-meta">
        <time class="blog-date" datetime={publishedAt.toISOString()}>
          {labels.blog.publishedAt}
          {formattedPublishedAt}
        </time>
        {
          updatedAt && (
            <time class="blog-date" datetime={updatedAt.toISOString()}>
              {labels.updatedAt}
              {formattedUpdatedAt}
            </time>
          )
        }
        {
          tags.length > 0 && (
            <div class="blog-tags">
              <span class="blog-tags-label">{labels.blog.tags}</span>
              {tags.map((tag) => (
                <Badge size="sm">{tag}</Badge>
              ))}
            </div>
          )
        }
      </div>
    </SectionBlock>

    <div class="blog-body">
      <article class="blog-content">
        <slot />
      </article>
    </div>

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .blog-title {
    margin-top: var(--space-md);
    max-width: 16ch;
  }

  .blog-description {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lede);
    line-height: var(--leading-snug);
    margin-top: var(--space-md);
    max-width: 60ch;
    color: var(--color-text-muted);
  }

  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding-block: var(--space-md);
    border-top: var(--line);
    border-bottom: var(--line);
  }

  .blog-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
  }

  .blog-tags-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
  }

  .blog-body {
    max-width: var(--container-md);
    margin-inline: auto;
    padding-inline: var(--space-md);
    padding-block: var(--space-xl);
    min-width: 0;
  }

  .blog-content {
    min-width: 0;
  }

  /* prose styles for Markdown slot content */
  .blog-content :global(h2) {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    scroll-margin-top: var(--space-xl);
  }

  .blog-content :global(h3) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }

  .blog-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .blog-content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .blog-content :global(figure),
  .blog-content :global(pre) {
    content-visibility: auto;
    contain-intrinsic-size: auto 320px;
  }

  /* pull quote — the serif moment with a 2px signal rule */
  .blog-content :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-lg);
    margin-block: var(--space-xl);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
  }

  .blog-content :global(hr) {
    border: none;
    border-top: var(--line);
    margin-block: var(--space-2xl);
  }

  .blog-content :global(img) {
    border: var(--line);
    border-radius: var(--radius-sm);
  }

  /* editorial table — hairline rules, no fills */
  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    border-top: var(--line);
    border-bottom: var(--line);
    margin-block: var(--space-lg);
    display: block;
    overflow-x: auto;
  }

  .blog-content :global(thead) {
    display: table;
    width: 100%;
    table-layout: fixed;
  }

  .blog-content :global(tbody) {
    display: table;
    width: 100%;
    table-layout: fixed;
  }

  .blog-content :global(th) {
    background: transparent;
    color: var(--color-heading);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-ink);
  }

  .blog-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: var(--line);
    font-size: var(--text-sm);
    vertical-align: top;
  }

  .blog-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .blog-content :global(h2:first-child) {
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .blog-body {
      padding-inline: var(--space-xl);
      padding-block: var(--space-3xl);
    }

    .blog-content :global(h2) {
      margin-top: var(--space-4xl);
      margin-bottom: var(--space-lg);
    }

    .blog-content :global(h3) {
      margin-top: var(--space-3xl);
      margin-bottom: var(--space-md);
    }

    .blog-content :global(p),
    .blog-content :global(ul),
    .blog-content :global(ol) {
      margin-bottom: var(--space-lg);
    }
  }
</style>
