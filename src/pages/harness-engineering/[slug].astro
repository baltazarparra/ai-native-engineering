---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Button from '../../components/Button/Button.astro';
import {
  HARNESS_REDIRECTS,
  getHarnessRedirectAlternateLinks,
} from '../../data/harness-redirects';
import { getSessionHref } from '../../lib/i18n';

export function getStaticPaths() {
  return HARNESS_REDIRECTS.map((redirect) => ({
    params: { slug: redirect.slug['pt-BR'] },
    props: { redirectId: redirect.id },
  }));
}

const lang = 'pt-BR';
const { redirectId } = Astro.props;
const target = getSessionHref(lang, 'maturidade');
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks = getHarnessRedirectAlternateLinks(redirectId);
---

<BaseLayout
  title="Capítulo movido | AI-Native Engineers"
  description="Este capítulo de Harness Engineering foi fundido com a aula SDD e Harness Design."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>Este capítulo foi fundido</h1>
      <p>
        A série Harness Engineering foi descontinuada. O conteúdo vive agora na
        aula <strong>SDD e Harness Design</strong>.
      </p>
      <Button href={target} size="lg">Ir para a aula atualizada</Button>
    </SectionBlock>
  </main>
</BaseLayout>
