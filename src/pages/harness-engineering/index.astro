---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Button from '../../components/Button/Button.astro';
import {
  getHarnessAlternateLinks,
  getSessionHref,
} from '../../lib/i18n';

const lang = 'pt-BR';
const target = getSessionHref(lang, 'maturidade');
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks = getHarnessAlternateLinks();
---

<BaseLayout
  title="Série movida | AI-Native Engineers"
  description="A série Harness Engineering foi fundida com a aula SDD e Harness Design."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>Esta série foi fundida</h1>
      <p>
        O conteúdo de Harness Engineering agora faz parte da aula
        <strong>SDD e Harness Design</strong>, com o fluxo completo para entrega
        profissional com agentes.
      </p>
      <Button href={target} size="lg">Ir para a aula atualizada</Button>
    </SectionBlock>
  </main>
</BaseLayout>
