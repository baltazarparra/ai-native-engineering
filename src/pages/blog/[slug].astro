---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Footer from '../../components/Footer/Footer.astro';
import BlogProse from '../../components/blog/BlogProse.module.css';
import {
  getPublishedBlogPosts,
  trimMetaDescription,
} from '../../lib/blog';
import { withBase } from '../../lib/i18n';
import styles from './blog-post.module.css';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedBlogPosts('pt-BR');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
};

const lang = 'pt-BR';
const { post } = Astro.props;
const { Content } = await render(post);

const pageTitle = `${post.data.title} | AI-Native Engineers`;
const description = trimMetaDescription(post.data.summary);

const publishedLabel = post.data.publishedAt.toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const coverSrc = post.data.cover
  ? post.data.cover.startsWith('http://') ||
    post.data.cover.startsWith('https://')
    ? post.data.cover
    : withBase(post.data.cover.replace(/^\//, ''))
  : null;

const ogImage = coverSrc
  ? coverSrc.startsWith('http')
    ? coverSrc
    : new URL(coverSrc, Astro.site).href
  : undefined;

const listHref = withBase('blog/');
const updatedAt = post.data.updatedAt ?? post.data.publishedAt;
---

<BaseLayout
  title={pageTitle}
  description={description}
  lang={lang}
  ogType="article"
  ogImage={ogImage}
  publishedAt={post.data.publishedAt}
  updatedAt={updatedAt}
>
  <main id="main-content">
    <article>
      <SectionBlock as="header" padding="xl">
        <nav aria-label="Navegação do blog">
          <a href={listHref} class:list={[styles.backLink]}
            >&larr; Voltar ao blog</a
          >
        </nav>
        <h1>{post.data.title}</h1>
        <p class:list={[styles.metaRow]}>
          <time datetime={post.data.publishedAt.toISOString()}>
            {publishedLabel}
          </time>
          {
            post.data.tags.length > 0 ? (
              <>
                <span class:list={[styles.metaSep]} aria-hidden="true">
                  ·
                </span>
                <span class:list={[styles.tags]}>
                  {post.data.tags.join(', ')}
                </span>
              </>
            ) : null
          }
        </p>
        {
          coverSrc ? (
            <div class:list={[styles.hero]}>
              <img
                class:list={[styles.heroImg]}
                src={coverSrc}
                alt=""
                width={960}
                height={540}
                loading="eager"
                decoding="async"
              />
            </div>
          ) : null
        }
      </SectionBlock>

      <SectionBlock padding="lg">
        <div class:list={[styles.articleBody, BlogProse.prose]}>
          <Content />
        </div>
      </SectionBlock>
    </article>
  </main>
  <Footer lang={lang} />
</BaseLayout>
