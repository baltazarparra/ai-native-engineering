---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Footer from '../../components/Footer/Footer.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getPublishedBlogPosts } from '../../lib/blog';
import listStyles from './blog-index.module.css';

const lang = 'pt-BR';
const posts = await getPublishedBlogPosts(lang);

const pageTitle = 'Blog | AI-Native Engineers';
const description =
  'Artigos sobre engenharia orientada por IA — contexto, validação e fluxo.';
---

<BaseLayout title={pageTitle} description={description} lang={lang}>
  <main id="main-content">
    <SectionBlock as="header" padding="xl">
      <h1>Blog</h1>
      <p class:list={[listStyles.pageIntro]}>
        Publicações em MDX no repositório — versionadas, revisáveis e geradas no
        build do site, em ordem da data mais recente.
      </p>
    </SectionBlock>

    {
      posts.length === 0 ? (
        <SectionBlock padding="lg">
          <h2 class:list={[listStyles.emptyTitle]}>Nenhuma publicação ainda</h2>
          <p class:list={[listStyles.emptyBody]}>
            Crie um arquivo em <code>src/content/blog/</code> com{' '}
            <code>draft: false</code> e rode o build para ver a lista aqui.
          </p>
        </SectionBlock>
      ) : (
        <SectionBlock padding="lg">
          <ul class:list={[listStyles.listReset, listStyles.stack]} role="list">
            {posts.map((post) => (
              <li>
                <PostCard
                  title={post.data.title}
                  slug={post.data.slug}
                  summary={post.data.summary}
                  publishedAt={post.data.publishedAt}
                  cover={post.data.cover}
                  tags={post.data.tags}
                />
              </li>
            ))}
          </ul>
        </SectionBlock>
      )
    }
  </main>
  <Footer lang={lang} />
</BaseLayout>
