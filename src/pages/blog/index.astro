---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Footer from '../../components/Footer/Footer.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getPosts } from '../../lib/notion';
import listStyles from './blog-index.module.css';

const lang = 'pt-BR';
const posts = await getPosts();

const pageTitle = 'Blog | AI-Native Engineers';
const description =
  'Artigos sobre engenharia orientada por IA — contexto, validação e fluxo.';
---

<BaseLayout title={pageTitle} description={description} lang={lang}>
  <main id="main-content">
    <SectionBlock as="header" padding="xl">
      <h1>Blog</h1>
      <p class:list={[listStyles.pageIntro]}>
        Publicações vindas do Notion. Quando há conteúdo publicado como
        “Published”, ele aparece aqui em ordem de data mais recente.
      </p>
    </SectionBlock>

    {
      posts.length === 0 ? (
        <SectionBlock padding="lg">
          <h2 class:list={[listStyles.emptyTitle]}>Nenhuma publicação ainda</h2>
          <p class:list={[listStyles.emptyBody]}>
            Não há páginas com status “Published” no banco configurado (ou ele
            está vazio). Publique pelo menos uma entrada no Notion com Slug válido
            para ver esta lista aqui — o site continua a ser gerado corretamente
            mesmo assim.
          </p>
        </SectionBlock>
      ) : (
        <SectionBlock padding="lg">
          <ul class:list={[listStyles.listReset, listStyles.stack]} role="list">
            {posts.map((post) => (
              <li>
                <PostCard
                  title={post.title}
                  slug={post.slug}
                  summary={post.summary}
                  publishedAt={post.publishedAt}
                  coverUrl={post.coverUrl}
                />
              </li>
            ))}
          </ul>
        </SectionBlock>
      )
    }
  </main>
  <Footer lang={lang} />
</BaseLayout>
