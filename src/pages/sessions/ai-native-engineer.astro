---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Button from '../../components/Button/Button.astro';
import {
  getHomeHref,
  getSessionHref,
  type AlternateLink,
} from '../../lib/i18n';

const lang = 'pt-BR';
const target = getHomeHref(lang);
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks: AlternateLink[] = [
  { lang: 'pt-BR', href: getSessionHref('pt-BR', 'ai-native-engineer') },
  { lang: 'en', href: getSessionHref('en', 'what-is-ai-native-engineer') },
  { lang: 'x-default', href: getSessionHref('pt-BR', 'ai-native-engineer') },
];
---

<BaseLayout
  title="Fundamentos movidos | AI-Native Engineers"
  description="A antiga sessão 0 foi descontinuada. Você será redirecionado para a página inicial."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>Esta página foi descontinuada</h1>
      <p>
        A antiga sessão 0 não existe mais. Comece pelas aulas na página inicial.
      </p>
      <Button href={target} size="lg">Ir para a home</Button>
    </SectionBlock>
  </main>
</BaseLayout>
