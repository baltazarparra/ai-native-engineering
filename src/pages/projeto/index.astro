---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Footer from '../../components/Footer/Footer.astro';
import ChapterStepper from '../../components/ChapterStepper/ChapterStepper.tsx';
import HackerNewsNewspaper from '../../components/HackerNewsNewspaper/HackerNewsNewspaper.tsx';
import Breadcrumbs from '../../components/Breadcrumbs/Breadcrumbs.astro';
import { ui, getProjectAlternateLinks, getHomeHref } from '../../lib/i18n';

const lang = 'pt-BR';
const labels = ui[lang].project;
const alternateLinks = getProjectAlternateLinks();
const breadcrumbItems = [
  { label: ui[lang].breadcrumb.home, href: getHomeHref(lang) },
  { label: labels.title },
];
---

<BaseLayout
  title={`${labels.title} | AI-Native Engineers`}
  description={labels.summary}
  lang={lang}
  alternateLinks={alternateLinks}
>
  <main id="main-content" class="project-landing">
    <SectionBlock as="header" padding="xl">
      <Breadcrumbs items={breadcrumbItems} lang={lang} />
      <span class="kicker">{labels.heroLabel}</span>
      <h1 class="landing-title">{labels.heading}</h1>
      <p class="landing-summary">
        Um guia prático para criar um jornal de notícias ao vivo com a
        HackerNews API, publicado no GitHub Pages.
      </p>
    </SectionBlock>

    <SectionBlock padding="lg" alt>
      <h2 class="section-heading">O que você vai construir</h2>
      <p>
        Um jornal de notícias estático que busca as <strong>top 10 stories do Hacker News</strong>
        em tempo real e exibe como uma página de jornal: manchete principal,
        seção de matérias e listagem numerada. Tudo consumindo a
        <strong>API pública do HackerNews</strong> (sem autenticação), publicado
        no seu <strong>GitHub Pages</strong>.
      </p>
      <p>
        O projeto é o veículo. O que você vai aprender de verdade é o fluxo
        <strong>AI-Native Engineers</strong>: contexto, planejamento com
        ROADMAP.md e DEV_PLAN.md, execução por fases e publicação.
      </p>
    </SectionBlock>

    <SectionBlock padding="lg">
      <span class="kicker">Demo ao vivo</span>
      <h2 class="section-heading demo-heading">Este é o projeto que você vai construir</h2>
      <p class="demo-desc">
        O componente abaixo faz fetch da HackerNews API agora e renderiza as
        histórias no layout de jornal que você vai criar do zero.
      </p>
      <HackerNewsNewspaper client:load lang={lang} />
    </SectionBlock>

    <SectionBlock padding="lg" alt>
      <h2 class="section-heading">Pré-requisitos</h2>
      <ul class="prereq-list">
        <li>Conta no <strong>GitHub</strong></li>
        <li>
          Ferramenta com IA configurada: IDE com IA integrada (Cursor,
          Windsurf), CLI de IA no terminal (Claude Code, OpenCode) ou assistente
          de IDE (Copilot, etc.)
        </li>
        <li>LLM configurada na ferramenta (Claude, GPT, Gemini, etc.)</li>
      </ul>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h2 class="section-heading">Seu progresso</h2>
      <ChapterStepper client:visible lang={lang} />
    </SectionBlock>

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .landing-title {
    margin-top: var(--space-md);
    max-width: 18ch;
  }

  .landing-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-md);
    max-width: 68ch;
    color: var(--color-text-muted);
  }

  .section-heading {
    margin-bottom: var(--space-md);
  }

  .demo-heading {
    margin-top: var(--space-sm);
  }

  .demo-desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    max-width: 64ch;
  }

  .prereq-list {
    padding-left: var(--space-lg);
  }

  .prereq-list li {
    margin-bottom: var(--space-xs);
  }
</style>
