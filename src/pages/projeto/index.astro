---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Badge from '../../components/Badge/Badge.astro';
import Footer from '../../components/Footer/Footer.astro';
import ChapterStepper from '../../components/ChapterStepper/ChapterStepper.tsx';
import { ui, getProjectAlternateLinks } from '../../lib/i18n';

const lang = 'pt-BR';
const labels = ui[lang].project;
const alternateLinks = getProjectAlternateLinks();
---

<BaseLayout
  title={`${labels.title} | AI-Native Engineering`}
  description={labels.summary}
  lang={lang}
  alternateLinks={alternateLinks}
>
  <main id="main-content" class="project-landing">
    <SectionBlock as="header" padding="xl">
      <Badge variant="coral">{labels.heroLabel}</Badge>
      <h1 class="landing-title">{labels.heading}</h1>
      <p class="landing-summary">{labels.summary}</p>
    </SectionBlock>

    <SectionBlock padding="lg" alt>
      <h2 class="section-heading">O que você vai construir</h2>
      <p>
        Um site onde você digita o nome de um artista, vê a discografia com
        capas de álbum, e clica em um álbum para ver a tracklist e detalhes.
        Tudo consumindo a <strong>API pública do Deezer</strong>, publicado no
        seu
        <strong>GitHub Pages</strong>.
      </p>
      <p>
        O projeto é o veículo — o que você vai aprender de verdade é o
        <strong>fluxo agêntico de desenvolvimento</strong>: contexto,
        planejamento, execução por partes e publicação.
      </p>
    </SectionBlock>

    <SectionBlock padding="lg">
      <h2 class="section-heading">Pré-requisitos</h2>
      <ul class="prereq-list">
        <li>Conta no <strong>GitHub</strong></li>
        <li>
          Ferramenta com IA configurada (Cursor, Windsurf, Claude Code, etc.)
        </li>
        <li>LLM configurada na ferramenta (Claude, GPT, Gemini, etc.)</li>
      </ul>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2 class="section-heading">Seu progresso</h2>
      <ChapterStepper client:visible lang={lang} />
    </SectionBlock>

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .landing-title {
    margin-top: var(--space-md);
    max-width: 18ch;
  }

  .landing-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-md);
    max-width: 68ch;
    color: var(--color-text-muted);
  }

  .section-heading {
    margin-bottom: var(--space-md);
  }

  .prereq-list {
    padding-left: var(--space-lg);
  }

  .prereq-list li {
    margin-bottom: var(--space-xs);
  }
</style>
