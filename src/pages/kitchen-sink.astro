---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Grid from '../components/Grid/Grid.astro';
import Button from '../components/Button/Button.astro';
import Card from '../components/Card/Card.astro';
import Badge from '../components/Badge/Badge.astro';
import { withBase } from '../lib/i18n';

const base = import.meta.env.BASE_URL;
const lang = 'pt-BR';
const alternateLinks = [
  { lang: 'pt-BR' as const, href: withBase('kitchen-sink'), label: 'PT-BR' },
  { lang: 'en' as const, href: withBase('en/kitchen-sink'), label: 'English' },
  { lang: 'x-default' as const, href: withBase('kitchen-sink') },
];
---

<BaseLayout
  title="Kitchen Sink | Dev"
  description="Página de dev pra ver todos os componentes"
  noindex
  lang={lang}
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <SectionBlock padding="xl">
      <span class="kicker">The Institute: design system</span>
      <h1>Kitchen Sink</h1>
      <p>
        Todos os componentes do sistema editorial em todos os estados. Esta
        página é permanente (dev-only): é a referência visual de cada fase do
        redesign e o checklist de regressão antes de cada commit.
      </p>
    </SectionBlock>

    <!-- typography -->
    <SectionBlock padding="xl" alt>
      <h2>Tipografia</h2>
      <span class="kicker"
        >Kicker / eyebrow: uppercase 12px tracking 0.12em</span
      >
      <h1>Heading 1: Inter Tight Bold, tracking -0.02em</h1>
      <p
        style="font-family: var(--font-serif); font-style: italic; font-size: var(--text-lede); line-height: var(--leading-snug); color: var(--color-text-muted);"
      >
        Lede em serif itálico: o momento serifado do sistema, usado no hero da
        home, em pull quotes e na faixa manifesto.
      </p>
      <h2>Heading 2: o subtítulo grandão</h2>
      <h3>Heading 3: seções dentro de seções</h3>
      <h4>Heading 4: labels importantes</h4>
      <h5>Heading 5: detalhes</h5>
      <h6>Heading 6: o menor que existe</h6>
      <p>
        Parágrafo normal em Inter 400. A gente precisa garantir que esse texto é
        confortável de ler em qualquer tela. Linha comprida demais cansa, curta
        demais quebra o ritmo. 68ch de max-width resolve isso.
      </p>
      <p>
        <strong>Texto em negrito (Inter 600)</strong> pra quando precisa de ênfase.
      </p>
      <p>
        E aqui um <code>trecho de código inline</code> em JetBrains Mono.
      </p>
      <pre><code>// bloco de código
const resultado = await modelo.gerar(prompt);
console.log(resultado);</code></pre>
    </SectionBlock>

    <!-- colors -->
    <SectionBlock padding="xl">
      <h2>Paleta de cores</h2>
      <p>
        Um único acento: o vermelho-sinal. O resto é papel, tinta e fios de
        cabelo. No dark, o acento clareia para manter contraste.
      </p>
      <Grid columns={4} gap="md">
        <div
          style="background: var(--color-surface); border: var(--line); padding: 1rem;"
        >
          surface<br />papel
        </div>
        <div
          style="background: var(--color-surface-alt); border: var(--line); padding: 1rem;"
        >
          surface-alt<br />faixa
        </div>
        <div
          style="background: var(--color-surface-raised); border: var(--line); padding: 1rem;"
        >
          raised<br />cards
        </div>
        <div
          style="background: var(--color-line); border: var(--line); padding: 1rem;"
        >
          line<br />hairline 1px
        </div>
        <div
          style="background: var(--color-ink); color: var(--color-fg-on-ink); border: var(--line); padding: 1rem;"
        >
          ink<br />botão primário
        </div>
        <div
          style="background: var(--color-text); color: var(--color-surface); border: var(--line); padding: 1rem;"
        >
          text<br />corpo
        </div>
        <div
          style="background: var(--color-text-muted); color: var(--color-surface); border: var(--line); padding: 1rem;"
        >
          muted<br />secundário
        </div>
        <div
          style="background: var(--color-heading); color: var(--color-surface); border: var(--line); padding: 1rem;"
        >
          heading<br />display
        </div>
        <div
          style="background: var(--color-accent); color: var(--color-fg-on-accent); border: var(--line); padding: 1rem;"
        >
          accent<br />vermelho-sinal
        </div>
        <div
          style="background: var(--color-accent-strong); color: var(--color-fg-on-accent); border: var(--line); padding: 1rem;"
        >
          accent-strong<br />hover
        </div>
        <div
          style="background: var(--color-focus); color: #ffffff; border: var(--line); padding: 1rem;"
        >
          focus<br />anel de foco
        </div>
        <div
          style="background: var(--color-code-bg); color: var(--color-code-fg); border: var(--line); padding: 1rem;"
        >
          code<br />sempre escuro
        </div>
      </Grid>
    </SectionBlock>

    <!-- badges -->
    <SectionBlock padding="xl" alt>
      <h2>Badges / Labels</h2>
      <p>
        Níveis não usam mais cor: todo badge é um chip neutro de hairline. O
        único colorido é o <code>accent</code>, reservado para destaques reais.
      </p>
      <div
        style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;"
      >
        <Badge>default</Badge>
        <Badge variant="yellow">beginner</Badge>
        <Badge variant="blue">intermediate</Badge>
        <Badge variant="green">advanced</Badge>
        <Badge variant="accent">Novo</Badge>
        <Badge size="sm">tag pequena</Badge>
        <Badge size="sm" variant="coral">5 min de leitura</Badge>
      </div>
    </SectionBlock>

    <!-- buttons -->
    <SectionBlock padding="xl">
      <h2>Botões</h2>

      <h3>Primary: tinta sólida, vermelho no hover</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button size="sm">Pequeno</Button>
        <Button>Normal</Button>
        <Button size="lg">Grandão</Button>
        <Button disabled>Desabilitado</Button>
      </div>

      <h3>Secondary: contorno de tinta, preenche no hover</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button variant="secondary" size="sm">Pequeno</Button>
        <Button variant="secondary">Normal</Button>
        <Button variant="secondary" size="lg">Grandão</Button>
      </div>

      <h3>Ghost: texto sublinhado</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button variant="ghost">Link disfarçado</Button>
      </div>

      <h3>Full width</h3>
      <div style="margin-bottom: var(--space-xl);">
        <Button fullWidth>Botão que ocupa tudo</Button>
      </div>

      <h3>Como link</h3>
      <Button href={base}>Voltar pra home</Button>
    </SectionBlock>

    <!-- cards -->
    <SectionBlock padding="xl" alt>
      <h2>Cards</h2>

      <h3>Cards simples</h3>
      <Grid columns={3} gap="lg">
        <Card title="Card neutro">
          <p>Hairline de 1px, sem sombra. A hierarquia vem do tipo e do ar.</p>
        </Card>
        <Card title="Com numeral" index="01">
          <p>O numeral editorial opcional, para listas tipo currículo.</p>
          <Fragment slot="footer">
            <Button variant="secondary" size="sm">Ver mais</Button>
          </Fragment>
        </Card>
        <Card title="Com fio vermelho" accent="yellow">
          <p>
            Qualquer valor legado de <code>accent</code> vira o mesmo filete vermelho
            de 2px no topo.
          </p>
          <Fragment slot="meta">
            <Badge>intermediate</Badge>
            <Badge size="sm">8 min</Badge>
          </Fragment>
        </Card>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h3>Card como link</h3>
      <Grid columns={2} gap="lg">
        <Card title="Clicável inteiro" href={base} index="02">
          <p>
            Esse card todo é um link. Hover escurece a borda e sublinha o
            título.
          </p>
        </Card>
        <Card title="Outro link" href={base}>
          <p>Nada levanta, nada empurra. Só cor e sublinhado.</p>
        </Card>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h3>Cards expansíveis</h3>
      <div style="display: flex; flex-direction: column; gap: var(--space-md);">
        <Card title="O que é um LLM?" expandable>
          <p>
            <strong>Versão simples:</strong> é um programa de computador treinado
            pra ler e escrever texto.
          </p>
          <p>
            <strong>Versão técnica:</strong> Large Language Model. Rede neural treinada
            em grandes volumes de texto que gera saída token a token com base em probabilidade
            condicional.
          </p>
        </Card>
        <Card title="O que é um agente?" expandable open>
          <p>Esse já começa aberto pra mostrar que dá.</p>
        </Card>
      </div>
    </SectionBlock>

    <!-- grid demos -->
    <SectionBlock padding="xl">
      <h2>Grid</h2>

      <h3>2 colunas</h3>
      <Grid columns={2} gap="md">
        <div
          style="background: var(--color-surface-alt); border: var(--line); padding: 1rem;"
        >
          Col 1
        </div>
        <div
          style="background: var(--color-surface-alt); border: var(--line); padding: 1rem;"
        >
          Col 2
        </div>
      </Grid>

      <h3>3 colunas</h3>
      <Grid columns={3} gap="md">
        <div
          style="background: var(--color-surface-alt); border: var(--line); padding: 1rem;"
        >
          1
        </div>
        <div
          style="background: var(--color-accent); color: var(--color-fg-on-accent); border: var(--line); padding: 1rem;"
        >
          2: o único vermelho
        </div>
        <div
          style="background: var(--color-surface-alt); border: var(--line); padding: 1rem;"
        >
          3
        </div>
      </Grid>

      <h3>4 colunas</h3>
      <Grid columns={4} gap="sm">
        <div style="border: var(--line); padding: 1rem;">A</div>
        <div style="border: var(--line); padding: 1rem;">B</div>
        <div style="border: var(--line); padding: 1rem;">C</div>
        <div style="border: var(--line); padding: 1rem;">D</div>
      </Grid>
    </SectionBlock>

    <!-- section block variants -->
    <SectionBlock padding="sm">
      <h2>SectionBlock padding="sm"</h2>
      <p>Menos respiro.</p>
    </SectionBlock>
    <SectionBlock padding="xl" alt>
      <h2>SectionBlock padding="xl" alt</h2>
      <p>Mais respiro, fundo alternativo.</p>
    </SectionBlock>

    <!-- focus and keyboard -->
    <SectionBlock padding="xl">
      <h2>Foco e teclado</h2>
      <p>
        Navega com Tab por tudo aqui embaixo. O foco tem que ser MUITO óbvio.
      </p>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;"
      >
        <Button>Foco aqui</Button>
        <Button variant="secondary">E aqui</Button>
        <Button variant="ghost">E aqui também</Button>
        <a href="#">Link normal</a>
      </div>
    </SectionBlock>

    <!-- links -->
    <SectionBlock padding="xl" alt>
      <h2>Links</h2>
      <p>
        Um <a href="#">link normal inline</a> dentro de texto. Tinta + sublinhado;
        o vermelho só aparece no hover.
      </p>
      <p>
        Outro parágrafo com <a href="#">mais um link</a> pra ver o padrão se repetindo.
      </p>
    </SectionBlock>
  </main>
</BaseLayout>
