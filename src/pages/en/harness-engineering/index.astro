---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionBlock from '../../../components/SectionBlock/SectionBlock.astro';
import Button from '../../../components/Button/Button.astro';
import { getHarnessAlternateLinks, getSessionHref } from '../../../lib/i18n';

const lang = 'en';
const target = getSessionHref(lang, 'maturity');
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks = getHarnessAlternateLinks();
---

<BaseLayout
  title="Series moved | AI-Native Engineers"
  description="The Harness Engineering series was merged into the SDD and Harness Design lesson."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>This series was merged</h1>
      <p>
        Harness Engineering content now lives in the
        <strong>SDD and Harness Design</strong> lesson, with the full professional
        flow for agent delivery.
      </p>
      <Button href={target} size="lg">Go to the updated lesson</Button>
    </SectionBlock>
  </main>
</BaseLayout>
