---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionBlock from '../../../components/SectionBlock/SectionBlock.astro';
import Button from '../../../components/Button/Button.astro';
import {
  HARNESS_CHAPTERS,
  getHarnessChapterAlternateLinks,
} from '../../../data/harness-chapters';
import { getSessionHref } from '../../../lib/i18n';

export function getStaticPaths() {
  return HARNESS_CHAPTERS.map((chapter) => ({
    params: { slug: chapter.slug.en },
    props: { chapterId: chapter.id },
  }));
}

const lang = 'en';
const { chapterId } = Astro.props;
const target = getSessionHref(lang, 'maturity');
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks = getHarnessChapterAlternateLinks(chapterId);
---

<BaseLayout
  title="Chapter moved | AI-Native Engineers"
  description="This Harness Engineering chapter was merged into the SDD and Harness Design lesson."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>This chapter was merged</h1>
      <p>
        The Harness Engineering series was discontinued. The content now lives
        in the <strong>SDD and Harness Design</strong> lesson.
      </p>
      <Button href={target} size="lg">Go to the updated lesson</Button>
    </SectionBlock>
  </main>
</BaseLayout>
