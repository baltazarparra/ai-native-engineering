---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Button from '../../components/Button/Button.astro';
import { getHomeAlternateLinks, getHomeHref } from '../../lib/i18n';

const lang = 'en';
---

<BaseLayout
  title="404 - Page not found | AI-Native Engineers"
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <main id="main-content">
    <SectionBlock padding="xl">
      <div class="error-page">
        <span class="error-code">404</span>
        <h1>This page does not exist</h1>
        <p>
          Could be an old link, a typo, or a page that moved. No stress: the
          content you want is probably on the home page.
        </p>
        <div class="error-actions">
          <Button href={getHomeHref(lang)} size="lg">Back home</Button>
          <Button href={`${getHomeHref(lang)}#sessions`} variant="secondary"
            >See lessons</Button
          >
        </div>
      </div>
    </SectionBlock>
  </main>
</BaseLayout>

<style>
  .error-page {
    text-align: center;
    padding-block: var(--space-3xl);
  }

  .error-code {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--weight-extrabold);
    font-size: clamp(4rem, 2rem + 10vw, 9rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-heading);
  }

  .error-page h1 {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .error-page p {
    margin-inline: auto;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .error-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  @media (max-width: 767px) {
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
