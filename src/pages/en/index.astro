---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card/Card.astro';
import Footer from '../../components/Footer/Footer.astro';
import Reveal from '../../components/motion/Reveal.tsx';
import { getSessions } from '../../data/sessions';
import { TRACKABLE_CHAPTERS, getChapterHref } from '../../data/chapters';
import { getPublishedPosts } from '../../lib/blog';
import {
  getBlogHref,
  getHomeAlternateLinks,
  getProjectHref,
  getSessionHref,
  ui,
} from '../../lib/i18n';
import { siteLinks } from '../../lib/siteLinks';

const lang = 'en';
const t = ui[lang];

const sortedSessions = getSessions(lang);
const projectChapters = TRACKABLE_CHAPTERS;
const latestPosts = (await getPublishedPosts(lang)).slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString(t.dateLocale, {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
---

<BaseLayout
  title="AI-Native Engineers"
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero" aria-label="Introduction">
    <div class="container">
      <Reveal client:load delay={0.08}>
        <h1 class="hero__title">
          AI-Native Engineers<span class="accent-dot">.</span>
        </h1>
      </Reveal>
      <Reveal client:load delay={0.16}>
        <p class="hero__lede">
          Learn to design the environment in which AI agents work:
          specification, context, validation, and responsibility.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ═══════════ MANIFESTO ═══════════ -->
  <section class="manifesto section" aria-label="Manifesto">
    <div class="container">
      <Reveal client:visible>
        <p class="manifesto__text">
          Code stops being the central artifact. The central artifact becomes
          the
          <strong>environment</strong>: specifications, agents, context,
          validation, and responsibility.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- ═══════════ SESSIONS ═══════════ -->
  <section class="sessions section" id="sessions">
    <div class="container">
      <header class="section-head">
        <h2 class="section-head__title">The concept in three parts</h2>
        <p class="section-head__lede">
          Vocabulary, tools, and method for moving beyond the demo and owning
          the system that produces the software.
        </p>
      </header>

      <Reveal client:visible>
        <div class="sessions__grid">
          {
            sortedSessions.map((session, i) => {
              const href = getSessionHref(lang, session.slug);
              const numeral = String(i + 1).padStart(2, '0');
              const meta = `${session.readingTime} min · ${t.levels[session.level]}`;

              return session.order === 3 ? (
                <a href={href} class="feature-card">
                  <div class="feature-card__head">
                    <span class="feature-card__numeral" aria-hidden="true">
                      {numeral}
                    </span>
                    <span class="feature-card__meta">{meta}</span>
                  </div>
                  <h3 class="feature-card__title">{session.title}</h3>
                  <p class="feature-card__summary">{session.summary}</p>
                  <span class="feature-card__arrow" aria-hidden="true">
                    →
                  </span>
                </a>
              ) : (
                <Card href={href} index={numeral} title={session.title}>
                  <Fragment slot="meta">{meta}</Fragment>
                  <p>{session.summary}</p>
                </Card>
              );
            })
          }
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ═══════════ PRIMER ═══════════ -->
  <section class="primer section" id="fundamentals">
    <div class="container">
      <header class="section-head">
        <h2 class="section-head__title">New terms</h2>
      </header>

      <Reveal client:visible>
        <div class="primer__blocks">
          <article class="pblock">
            <span class="pblock__numeral" aria-hidden="true">01</span>
            <h3 class="pblock__title">AI-Native Engineer</h3>
            <p>
              Someone who designs the environment agents work in: loops,
              specification, context, and responsibility. Not "a dev who uses
              Copilot".
            </p>
          </article>

          <article class="pblock">
            <span class="pblock__numeral" aria-hidden="true">02</span>
            <h3 class="pblock__title">AI agent</h3>
            <p>
              A program that pursues a goal in loops: it observes the
              environment, plans, acts with tools, checks the result, and
              repeats. Unlike a chat that only answers, an agent executes: it
              edits files, runs tests, navigates.
            </p>
          </article>

          <article class="pblock">
            <span class="pblock__numeral" aria-hidden="true">03</span>
            <h3 class="pblock__title">LLM (The Model)</h3>
            <p>
              Large Language Model — the "brain" that gives the AI agent its
              intelligence. Wired into the harness, the LLM processes the SDD
              definitions, analyzes the repository context, and makes
              mathematical decisions on every cycle.
            </p>
          </article>

          <article class="pblock">
            <span class="pblock__numeral" aria-hidden="true">04</span>
            <h3 class="pblock__title">SDD (Spec-Driven Development)</h3>
            <p>
              The primary artifact that defines the specification and the
              working method. The agent implements and validates the work from
              the definitions in the Spec.
            </p>
          </article>

          <article class="pblock">
            <span class="pblock__numeral" aria-hidden="true">05</span>
            <h3 class="pblock__title">Harness</h3>
            <p>
              The environment around the model: instructions, tools, memory,
              checks, and limits. It is the chassis the agent runs on, and it
              determines the quality of what comes out.
            </p>
          </article>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ═══════════ PROJECT ═══════════ -->
  <section class="section home-project" id="project">
    <div class="container">
      <header class="section-head">
        <h2 class="section-head__title">{t.project.heading}</h2>
        <p class="section-head__lede">{t.project.homeDesc}</p>
      </header>

      <Reveal client:visible>
        <div class="linkrows">
          <a class="linkrow" href={getProjectHref(lang)}>
            <span class="linkrow__title">{t.project.title}</span>
            <span class="linkrow__meta">{t.project.readingTime}</span>
          </a>
          {
            projectChapters.map((chapter) => (
              <a class="linkrow" href={getChapterHref(chapter.number, lang)}>
                <span class="linkrow__title">{chapter.title[lang]}</span>
                <span class="linkrow__meta">
                  {t.chapters.chapterLabel(chapter.number)}
                </span>
              </a>
            ))
          }
          <a class="linkrow" href={siteLinks.repository}>
            <span class="linkrow__title">Source code on GitHub</span>
            <span class="linkrow__meta">open repository</span>
          </a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ═══════════ BLOG ═══════════ -->
  <section class="section home-blog" id="blog">
    <div class="container">
      <header class="section-head">
        <h2 class="section-head__title">Writings</h2>
      </header>

      <Reveal client:visible>
        <div class="linkrows">
          {
            latestPosts.map((post) => (
              <a class="linkrow" href={getBlogHref(lang, post.data.slug)}>
                <span class="linkrow__title">{post.data.title}</span>
                <span class="linkrow__meta">
                  {post.data.author} · {formatDate(post.data.publishedAt)}
                </span>
              </a>
            ))
          }
        </div>
      </Reveal>
      <p class="section-more">
        <a class="text-link" href={getBlogHref(lang)}>{t.blog.homeCta} →</a>
      </p>
    </div>
  </section>
</BaseLayout>
<Footer lang={lang} />
<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    padding-block: var(--space-4xl) var(--space-3xl);
  }

  /* brand echo: the red square from the header, repeated on kickers */
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .kicker::before {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__title {
    font-size: var(--text-display);
    font-weight: var(--weight-extrabold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-block: var(--space-lg) var(--space-xl);
  }

  .accent-dot {
    color: var(--color-accent);
  }

  .hero__lede {
    font-family: var(--font-display);
    font-size: var(--text-lede);
    line-height: 1.4;
    color: var(--color-text-muted);
    max-width: 34ch;
    text-wrap: balance;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
  }

  /* ── Manifesto strip ──────────────────────────────────── */
  .manifesto {
    background: var(--color-ink);
    color: var(--color-fg-on-ink);
    padding-block: var(--space-3xl);
  }

  .manifesto__text {
    font-size: var(--text-lede);
    line-height: 1.5;
    max-width: 34ch;
  }

  .manifesto__text strong {
    color: var(--color-accent);
  }

  /* ── Section headers ──────────────────────────────────── */
  .section-head {
    position: relative;
    border-top: var(--line);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  /* red tick on the hairline — the accent rhythm down the page */
  .section-head::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--color-accent);
  }

  .section-head__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
  }

  .section-head .kicker + .section-head__title {
    margin-top: var(--space-sm);
  }

  .section-head__lede {
    font-size: var(--text-lede);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-top: var(--space-md);
  }

  /* ── Primer ───────────────────────────────────────────── */
  .primer__blocks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--space-2xl);
    row-gap: var(--space-2xl);
  }

  .pblock {
    border-top: 2px solid var(--color-ink);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .pblock__numeral {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .pblock__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    margin-block: var(--space-sm) var(--space-md);
  }

  .pblock p {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* ── Sessions ─────────────────────────────────────────── */
  .sessions__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    align-items: stretch;
  }

  .feature-card {
    grid-column: 1 / -1;
    display: block;
    background: var(--color-ink);
    color: var(--color-fg-on-ink);
    padding: var(--space-2xl);
    text-decoration: none;
    position: relative;
    transition: background var(--motion-fast) var(--ease-standard);
  }

  .feature-card:hover {
    background: var(--color-accent);
    color: var(--color-fg-on-accent);
  }

  .feature-card:hover .feature-card__meta,
  .feature-card:hover .feature-card__summary,
  .feature-card:hover .feature-card__arrow {
    color: var(--color-fg-on-accent);
  }

  .feature-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xl);
  }

  .feature-card__numeral {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .feature-card__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-fg-on-ink) 60%, transparent);
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .feature-card__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-fg-on-ink);
    margin-bottom: var(--space-md);
    max-width: 24ch;
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .feature-card:hover .feature-card__title {
    color: var(--color-fg-on-accent);
  }

  .feature-card__summary {
    font-size: var(--text-base);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-fg-on-ink) 75%, transparent);
    max-width: 58ch;
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .feature-card__arrow {
    position: absolute;
    right: var(--space-2xl);
    bottom: var(--space-2xl);
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--color-accent);
    transition: color var(--motion-fast) var(--ease-standard);
  }

  /* ── Harness ──────────────────────────────────────────── */
  .harness__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-2xl);
    row-gap: var(--space-2xl);
  }

  .hblock {
    border-top: 2px solid var(--color-ink);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .hblock h3 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-md);
  }

  .hblock p {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .hblock .text-link,
  .section-more .text-link {
    color: var(--color-accent);
  }

  /* ── Link rows (blog / project) ───────────────────────── */
  .linkrows {
    display: flex;
    flex-direction: column;
  }

  .linkrow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-xl);
    padding-block: var(--space-md);
    border-bottom: var(--line);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--motion-fast) var(--ease-standard);
  }

  .linkrow:first-child {
    border-top: var(--line);
  }

  .linkrow:hover {
    background: var(--color-surface-alt);
  }

  .linkrow__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .linkrow:hover .linkrow__title {
    color: var(--color-accent);
  }

  .linkrow__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: right;
    flex-shrink: 0;
  }

  .section-more {
    margin-top: var(--space-xl);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 1023px) {
    .primer__blocks {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-block: var(--space-3xl) var(--space-2xl);
    }

    .primer__blocks,
    .sessions__grid,
    .harness__grid {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding: var(--space-xl);
    }

    .feature-card__arrow {
      right: var(--space-xl);
      bottom: var(--space-xl);
    }

    .linkrow {
      flex-direction: column;
      gap: var(--space-2xs);
    }

    .linkrow__meta {
      text-align: left;
    }
  }
</style>
