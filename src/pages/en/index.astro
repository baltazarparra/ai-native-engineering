---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Grid from '../../components/Grid/Grid.astro';
import Button from '../../components/Button/Button.astro';
import Card from '../../components/Card/Card.astro';
import Badge from '../../components/Badge/Badge.astro';
import Footer from '../../components/Footer/Footer.astro';
import Discussion from '../../components/Discussion/Discussion.astro';
import HeroStickers from '../../components/HeroStickers/HeroStickers';
import HeroGhostCursors from '../../components/HeroGhostCursors/HeroGhostCursors';
import HeroCaptureCounter from '../../components/HeroCaptureCounter/HeroCaptureCounter';
import HeroCursorTrail from '../../components/HeroCursorTrail/HeroCursorTrail';
import { getSessions } from '../../data/sessions';
import {
  getHomeAlternateLinks,
  getSessionHref,
  getProjectHref,
  getHarnessHref,
  ui,
} from '../../lib/i18n';

const lang = 'en';
const sessions = getSessions(lang);
const levelLabels = ui[lang].levels;

function levelToBadgeVariant(level: string) {
  const map = {
    beginner: 'yellow',
    intermediate: 'blue',
    advanced: 'green',
  } as const;
  return map[level as keyof typeof map] || 'default';
}

function levelToLabel(level: string) {
  return levelLabels[level as keyof typeof levelLabels] || level;
}
---

<BaseLayout
  title="Software Engineering in the Age of AI"
  description="A practical guide for using AI in real software work, without hype and without panic."
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <main id="main-content">
    <HeroStickers client:visible lang={lang} />
    <SectionBlock as="header" padding="xl" maxWidth="lg">
      <div class="hero-layer" data-screen-shake>
        <HeroGhostCursors client:visible />
        <HeroCursorTrail client:visible />
        <div class="hero-content">
          <span class="hero-badge-row">
            <Badge variant="green">100% free and open source</Badge>
            <HeroCaptureCounter client:visible lang={lang} />
          </span>
          <h1 class="hero-title">Software Engineering in the Age of AI</h1>
          <p class="hero-tagline">
            A practical guide for using AI in real software work, without hype
            and without panic.
          </p>
          <Button href={getSessionHref(lang, sessions[0].slug)} size="lg">
            Start learning
          </Button>
        </div>
      </div>
    </SectionBlock>

    <SectionBlock padding="lg" id="sessions">
      <h2>Sessions</h2>
      <Grid columns={3} gap="lg" align="stretch">
        {
          sessions.map((session) => (
            <Card
              title={session.title}
              href={getSessionHref(lang, session.slug)}
              accent={session.accent}
            >
              <Fragment slot="meta">
                <Badge variant={levelToBadgeVariant(session.level)} size="sm">
                  {levelToLabel(session.level)}
                </Badge>
                <Badge size="sm">{session.readingTime} min</Badge>
              </Fragment>
              <p>{session.summary}</p>
              <Fragment slot="footer">
                <span class="session-order">Session {session.order}</span>
              </Fragment>
            </Card>
          ))
        }
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <div class="project-cta-block">
        <Badge variant="coral">New</Badge>
        <h2>Hands-on Project</h2>
        <p>
          When the theory clicks, put it to work: build a project from scratch
          with your code agent and publish it to GitHub Pages.
        </p>
        <Button href={getProjectHref(lang)} size="lg">
          Go to the hands-on project
        </Button>
      </div>
    </SectionBlock>

    <SectionBlock padding="xl">
      <div class="harness-cta-block">
        <div>
          <Badge variant="coral">Deep dive</Badge>
          <h2>Harness Engineering</h2>
          <p>
            After the sessions, go deeper into how context, tools, boundaries,
            and validation turn a model into a reliable agent. Session 3 shows
            how to operate; this series explains the system behind it.
          </p>
        </div>
        <Button href={getHarnessHref(lang)} size="lg">Understand harness</Button
        >
      </div>
    </SectionBlock>

    <Discussion
      lang={lang}
      slug="home"
      title="Software Engineering in the Age of AI"
    />

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .hero-layer {
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
  }

  .hero-badge-row {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-title {
    margin-top: var(--space-md);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 42ch;
    margin-block: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .session-order {
    font-family: var(--font-heading);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  :global(#sessions) {
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    :global(#sessions) {
      margin-bottom: var(--space-3xl);
    }
  }

  .project-cta-block {
    text-align: center;
    max-width: 42ch;
    margin-inline: auto;
  }

  .harness-cta-block {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
    border: var(--border-thick);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-raised);
    box-shadow: var(--shadow-lg);
    padding: var(--space-xl);
  }

  .harness-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .harness-cta-block p {
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 58ch;
  }

  .project-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .project-cta-block p {
    margin-block: var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  h2 + p {
    margin-block: var(--space-md);
  }

  @media (min-width: 768px) {
    .harness-cta-block {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }
</style>
