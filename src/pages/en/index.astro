---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Grid from '../../components/Grid/Grid.astro';
import Button from '../../components/Button/Button.astro';
import Card from '../../components/Card/Card.astro';
import Badge from '../../components/Badge/Badge.astro';
import Footer from '../../components/Footer/Footer.astro';
import Discussion from '../../components/Discussion/Discussion.astro';
import HomeFoundations from '../../components/HomeFoundations/HomeFoundations.astro';
import HeroStickers from '../../components/HeroStickers/HeroStickers';
import HeroGhostCursors from '../../components/HeroGhostCursors/HeroGhostCursors';
import { getSessions } from '../../data/sessions';
import {
  getHomeAlternateLinks,
  getSessionHref,
  getProjectHref,
  getSkillsHref,
} from '../../lib/i18n';

const lang = 'en';
const sessions = getSessions(lang);

function levelToBadgeVariant(level: string) {
  const map = {
    beginner: 'yellow',
    intermediate: 'blue',
    advanced: 'green',
  } as const;
  return map[level as keyof typeof map] || 'default';
}
---

<BaseLayout
  title="Software Engineering in the Age of AI"
  description="A practical guide for using AI in real software work, without hype and without panic."
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <main id="main-content">
    <SectionBlock as="header" padding="xl" maxWidth="lg">
      <div class="hero-layer">
        <HeroGhostCursors client:idle />
        <HeroStickers client:idle lang={lang} />
        <div class="hero-content">
          <Badge variant="green">100% free and open source</Badge>
          <h1 class="hero-title">Software Engineering in the Age of AI</h1>
          <p class="hero-tagline">
            A practical guide for using AI in real software work, without hype
            and without panic.
          </p>
          <Button href={getSessionHref(lang, sessions[0].slug)} size="lg">
            Start learning
          </Button>
        </div>
      </div>
    </SectionBlock>

    <HomeFoundations lang={lang} />

    <SectionBlock padding="xl" id="sessions">
      <h2>Sessions</h2>
      <Grid columns={3} gap="lg" align="stretch">
        {
          sessions.map((session) => (
            <Card
              title={session.title}
              href={getSessionHref(lang, session.slug)}
              accent={session.accent}
            >
              <Fragment slot="meta">
                <Badge variant={levelToBadgeVariant(session.level)} size="sm">
                  {session.level}
                </Badge>
                <Badge size="sm">{session.readingTime} min</Badge>
              </Fragment>
              <p>{session.summary}</p>
              <Fragment slot="footer">
                <span class="session-order">Session {session.order}</span>
              </Fragment>
            </Card>
          ))
        }
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <div class="project-cta-block">
        <Badge variant="coral">New</Badge>
        <h2>Hands-on Project</h2>
        <p>
          Done with theory? Build a project from scratch with your code agent
          and publish it to GitHub Pages. A practical guide that teaches the
          real agentic workflow.
        </p>
        <Button href={getProjectHref(lang)} size="lg">
          Go to the hands-on project
        </Button>
      </div>
    </SectionBlock>

    <SectionBlock padding="xl">
      <div class="skills-cta-block">
        <Badge variant="blue">Skills</Badge>
        <h2>Share process with your agents</h2>
        <p>
          Learn what skills are, how they help teams keep good habits, and
          install a quality gate with one NPX command.
        </p>
        <Button href={getSkillsHref(lang)} size="lg">Explore skills</Button>
      </div>
    </SectionBlock>

    <Discussion lang={lang} slug="home" title="Software Engineering in the Age of AI" />

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .hero-layer {
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
  }

  .hero-title {
    margin-top: var(--space-md);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 42ch;
    margin-block: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .session-order {
    font-family: var(--font-heading);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .project-cta-block {
    text-align: center;
    max-width: 42ch;
    margin-inline: auto;
  }

  .project-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .project-cta-block p {
    margin-block: var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .skills-cta-block {
    border: var(--border-thick);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-alt);
    box-shadow: var(--shadow-lg);
    padding: var(--space-xl);
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }

  .skills-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .skills-cta-block p {
    margin: var(--space-md) auto var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 54ch;
  }

  h2 + p {
    margin-block: var(--space-md);
  }
</style>
