---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionBlock from '../../../components/SectionBlock/SectionBlock.astro';
import Button from '../../../components/Button/Button.astro';
import { getSessionHref, type AlternateLink } from '../../../lib/i18n';

const lang = 'en';
const target = getSessionHref(lang, 'maturity');
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks: AlternateLink[] = [
  { lang: 'pt-BR', href: getSessionHref('pt-BR', 'como-operar') },
  { lang: 'en', href: getSessionHref('en', 'how-to-operate') },
  { lang: 'x-default', href: getSessionHref('pt-BR', 'como-operar') },
];
---

<BaseLayout
  title="Session moved | AI-Native Engineers"
  description="This session was merged into SDD and Harness Design."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>This session was merged</h1>
      <p>
        “How to operate” is now part of the
        <strong> SDD and Harness Design</strong> session, with a fuller workflow for
        professional AI-native development.
      </p>
      <Button href={target} size="lg">Go to the updated session</Button>
    </SectionBlock>
  </main>
</BaseLayout>
