---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionBlock from '../../../components/SectionBlock/SectionBlock.astro';
import Button from '../../../components/Button/Button.astro';
import {
  getHomeHref,
  getSessionHref,
  type AlternateLink,
} from '../../../lib/i18n';

const lang = 'en';
const target = `${getHomeHref(lang)}#foundations`;
const redirectScript = `window.location.replace(${JSON.stringify(target)});`;
const alternateLinks: AlternateLink[] = [
  { lang: 'pt-BR', href: getSessionHref('pt-BR', 'ai-native-engineer') },
  { lang: 'en', href: getSessionHref('en', 'what-is-ai-native-engineer') },
  { lang: 'x-default', href: getSessionHref('pt-BR', 'ai-native-engineer') },
];
---

<BaseLayout
  title="Foundations moved | AI-Native Engineers"
  description="The former session 0 is now summarized on the home page."
  lang={lang}
  noindex
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <script is:inline set:html={redirectScript} />
    <SectionBlock padding="xl">
      <h1>The foundations moved to the home page</h1>
      <p>
        The former session 0 is now summarized in three cards: AI-Native
        Engineer, AI agent, and coding agent.
      </p>
      <Button href={target} size="lg">See foundations</Button>
    </SectionBlock>
  </main>
</BaseLayout>
