---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import SessionLayout from '../../../layouts/SessionLayout.astro';
import { getSessionByOrder } from '../../../data/sessions';

export const getStaticPaths: GetStaticPaths = async () => {
  const sessionEntries = (await getCollection('sessions')).filter(
    (session) => session.data.lang === 'en',
  );
  const allReferences = await getCollection('references');

  return sessionEntries.map((session) => {
    const resolvedRefs = session.data.references
      .map((refId: string) => {
        const ref = allReferences.find((r) => r.id === refId);
        return ref ? ref.data : null;
      })
      .filter(Boolean);

    const currentOrder = session.data.order;
    const nextSessionData = getSessionByOrder(
      session.data.lang,
      currentOrder + 1,
    );
    const nextSession = nextSessionData
      ? {
          title: nextSessionData.title,
          slug: nextSessionData.slug,
          heroLabel: nextSessionData.heroLabel,
        }
      : null;

    return {
      params: { slug: session.data.slug },
      props: { session, resolvedRefs, nextSession },
    };
  });
};

const { session, resolvedRefs, nextSession } = Astro.props;
const { Content } = await render(session);
---

<SessionLayout
  title={session.data.title}
  slug={session.data.slug}
  lang={session.data.lang}
  translationKey={session.data.translationKey}
  summary={session.data.summary}
  readingTime={session.data.readingTime}
  level={session.data.level}
  heroLabel={session.data.heroLabel}
  updatedAt={session.data.updatedAt}
  tags={session.data.tags}
  order={session.data.order}
  references={resolvedRefs}
  nextSession={nextSession}
>
  <Content />
</SessionLayout>
