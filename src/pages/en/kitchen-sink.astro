---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionBlock from '../../components/SectionBlock/SectionBlock.astro';
import Grid from '../../components/Grid/Grid.astro';
import Button from '../../components/Button/Button.astro';
import Card from '../../components/Card/Card.astro';
import Badge from '../../components/Badge/Badge.astro';
import { withBase } from '../../lib/i18n';

const base = import.meta.env.BASE_URL;
const lang = 'en';
const alternateLinks = [
  { lang: 'pt-BR' as const, href: withBase('kitchen-sink'), label: 'PT-BR' },
  { lang: 'en' as const, href: withBase('en/kitchen-sink'), label: 'English' },
  { lang: 'x-default' as const, href: withBase('kitchen-sink') },
];
---

<BaseLayout
  title="Kitchen Sink | Dev"
  description="Dev page to preview every component"
  noindex
  lang={lang}
  alternateLinks={alternateLinks}
>
  <main id="main-content">
    <SectionBlock padding="xl">
      <h1>Kitchen Sink</h1>
      <p>
        Every design system component in every relevant state. This page is
        temporary and should disappear after Phase 2.
      </p>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2>Typography</h2>
      <h1>Heading 1 - Space Grotesk Bold</h1>
      <h2>Heading 2 - The big subtitle</h2>
      <h3>Heading 3 - Sections inside sections</h3>
      <h4>Heading 4 - Important labels</h4>
      <h5>Heading 5 - Details</h5>
      <h6>Heading 6 - The smallest one</h6>
      <p>
        Regular paragraph text in Inter 400. We need to make sure this remains
        comfortable to read on any screen. Lines that are too long are tiring,
        lines that are too short break the rhythm. A max width of 68ch helps.
      </p>
      <p>
        <strong>Bold text (Inter 600)</strong> for when emphasis is needed.
      </p>
      <p>And here is an <code>inline code snippet</code> in JetBrains Mono.</p>
      <pre><code>// code block
const result = await model.generate(prompt);
console.log(result);</code></pre>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h2>Color palette</h2>
      <p>
        Accent colors only work well as backgrounds with black text, except for
        blue which uses white.
      </p>
      <Grid columns={4} gap="md">
        <div
          style="background: var(--color-bg); border: var(--border-thick); padding: 1rem;"
        >
          bg<br />#faf5ee
        </div>
        <div
          style="background: var(--color-bg-alt); border: var(--border-thick); padding: 1rem;"
        >
          bg-alt<br />#f0e9df
        </div>
        <div
          style="background: var(--color-primary); color: var(--color-bg); border: var(--border-thick); padding: 1rem;"
        >
          primary<br />#000000
        </div>
        <div
          style="background: var(--color-text-muted); color: var(--color-bg); border: var(--border-thick); padding: 1rem;"
        >
          muted<br />#4a4a4a
        </div>
        <div
          style="background: var(--color-accent-1); border: var(--border-thick); padding: 1rem;"
        >
          accent-1<br />#f5c518
        </div>
        <div
          style="background: var(--color-accent-2); color: white; border: var(--border-thick); padding: 1rem;"
        >
          accent-2<br />#2952e8
        </div>
        <div
          style="background: var(--color-accent-3); border: var(--border-thick); padding: 1rem;"
        >
          accent-3<br />#00b34a
        </div>
        <div
          style="background: var(--color-accent-4); border: var(--border-thick); padding: 1rem;"
        >
          accent-4<br />#ff5c5c
        </div>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2>Badges / Labels</h2>
      <div
        style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;"
      >
        <Badge>default</Badge>
        <Badge variant="yellow">beginner</Badge>
        <Badge variant="blue">intermediate</Badge>
        <Badge variant="green">advanced</Badge>
        <Badge variant="coral">anti-pattern</Badge>
        <Badge size="sm">small tag</Badge>
        <Badge size="sm" variant="yellow">5 min read</Badge>
      </div>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h2>Buttons</h2>

      <h3>Primary</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button size="sm">Small</Button>
        <Button>Normal</Button>
        <Button size="lg">Large</Button>
        <Button disabled>Disabled</Button>
      </div>

      <h3>Secondary</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button variant="secondary" size="sm">Small</Button>
        <Button variant="secondary">Normal</Button>
        <Button variant="secondary" size="lg">Large</Button>
      </div>

      <h3>Ghost</h3>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: var(--space-xl);"
      >
        <Button variant="ghost">Disguised link</Button>
      </div>

      <h3>Full width</h3>
      <div style="margin-bottom: var(--space-xl);">
        <Button fullWidth>Full width button</Button>
      </div>

      <h3>As a link</h3>
      <Button href={base}>Back to home</Button>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2>Cards</h2>

      <h3>Simple cards with accents</h3>
      <Grid columns={3} gap="lg">
        <Card title="Card without accent">
          <p>Default card content. Thick black border and hard shadow.</p>
        </Card>
        <Card title="Yellow card" accent="yellow">
          <p>This one has a yellow strip at the top.</p>
          <Fragment slot="footer">
            <Button variant="secondary" size="sm">See more</Button>
          </Fragment>
        </Card>
        <Card title="Blue card" accent="blue">
          <p>Electric blue strip.</p>
          <Fragment slot="meta">
            <Badge variant="blue">intermediate</Badge>
            <Badge size="sm">8 min</Badge>
          </Fragment>
        </Card>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h3>Card as a link</h3>
      <Grid columns={2} gap="lg">
        <Card title="Fully clickable" href={base} accent="green">
          <p>The whole card is a link. Hover lifts it, click pushes it down.</p>
        </Card>
        <Card title="Another link" href={base} accent="coral">
          <p>Coral works well for anti-pattern examples.</p>
        </Card>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h3>Expandable cards</h3>
      <div style="display: flex; flex-direction: column; gap: var(--space-md);">
        <Card title="What is an LLM?" expandable accent="yellow">
          <p>
            <strong>Simple version:</strong> it is a computer program trained
            to read and write text.
          </p>
          <p>
            <strong>Technical version:</strong> Large Language Model. A neural
            network trained on large amounts of text that generates output
            token by token based on conditional probability.
          </p>
        </Card>
        <Card title="What is an agent?" expandable accent="blue" open>
          <p>This one starts open to show that state too.</p>
        </Card>
      </div>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h2>Grid</h2>

      <h3>2 columns</h3>
      <Grid columns={2} gap="md">
        <div
          style="background: var(--color-accent-1); border: var(--border-thick); padding: 1rem;"
        >
          Col 1
        </div>
        <div
          style="background: var(--color-accent-3); border: var(--border-thick); padding: 1rem;"
        >
          Col 2
        </div>
      </Grid>

      <h3>3 columns</h3>
      <Grid columns={3} gap="md">
        <div
          style="background: var(--color-accent-1); border: var(--border-thick); padding: 1rem;"
        >
          1
        </div>
        <div
          style="background: var(--color-accent-2); border: var(--border-thick); padding: 1rem; color: white;"
        >
          2
        </div>
        <div
          style="background: var(--color-accent-3); border: var(--border-thick); padding: 1rem;"
        >
          3
        </div>
      </Grid>

      <h3>4 columns</h3>
      <Grid columns={4} gap="sm">
        <div style="border: var(--border-thick); padding: 1rem;">A</div>
        <div style="border: var(--border-thick); padding: 1rem;">B</div>
        <div style="border: var(--border-thick); padding: 1rem;">C</div>
        <div style="border: var(--border-thick); padding: 1rem;">D</div>
      </Grid>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2>SectionBlock variants</h2>
      <SectionBlock padding="sm">
        <h2>SectionBlock padding="sm"</h2>
        <p>Less breathing room.</p>
      </SectionBlock>
      <SectionBlock padding="xl" alt>
        <h2>SectionBlock padding="xl" alt</h2>
        <p>More breathing room, alternate background.</p>
      </SectionBlock>
    </SectionBlock>

    <SectionBlock padding="xl">
      <h2>Focus and keyboard</h2>
      <p>Use Tab to navigate everything below. Focus needs to be VERY obvious.</p>
      <div
        style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;"
      >
        <Button>Focus here</Button>
        <Button variant="secondary">And here</Button>
        <Button variant="ghost">And here too</Button>
        <a href="#">Regular link</a>
      </div>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2>Links</h2>
      <p>
        A regular <a href="#">inline link</a> inside body text. It should feel
        obviously clickable without relying on color alone.
      </p>
      <p>
        Another paragraph with <a href="#">one more link</a> to check that the
        pattern stays consistent.
      </p>
    </SectionBlock>
  </main>
</BaseLayout>
