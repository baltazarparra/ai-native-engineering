---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionBlock from '../../../components/SectionBlock/SectionBlock.astro';
import Badge from '../../../components/Badge/Badge.astro';
import Footer from '../../../components/Footer/Footer.astro';
import ChapterStepper from '../../../components/ChapterStepper/ChapterStepper.tsx';
import { ui, getProjectAlternateLinks } from '../../../lib/i18n';

const lang = 'en';
const labels = ui[lang].project;
const alternateLinks = getProjectAlternateLinks();
---

<BaseLayout
  title={`${labels.title} | AI-Native Engineering`}
  description={labels.summary}
  lang={lang}
  alternateLinks={alternateLinks}
>
  <main id="main-content" class="project-landing">
    <SectionBlock as="header" padding="xl">
      <Badge variant="coral">{labels.heroLabel}</Badge>
      <h1 class="landing-title">{labels.heading}</h1>
      <p class="landing-summary">{labels.summary}</p>
    </SectionBlock>

    <SectionBlock padding="lg" alt>
      <h2 class="section-heading">What you'll build</h2>
      <p>
        A site where you type an artist's name, see their discography with album
        covers, and click an album to view the tracklist and details. All
        powered by the <strong>Deezer public API</strong>, published on your
        <strong>GitHub Pages</strong>.
      </p>
      <p>
        The project is the vehicle. What you'll actually learn is the
        <strong>agentic development workflow</strong>: context, planning, phased
        execution, and publishing.
      </p>
    </SectionBlock>

    <SectionBlock padding="lg">
      <h2 class="section-heading">Prerequisites</h2>
      <ul class="prereq-list">
        <li><strong>GitHub</strong> account</li>
        <li>
          AI-powered development tool configured (Cursor, Windsurf, Claude Code,
          etc.)
        </li>
        <li>LLM configured in your tool (Claude, GPT, Gemini, etc.)</li>
      </ul>
    </SectionBlock>

    <SectionBlock padding="xl" alt>
      <h2 class="section-heading">Your progress</h2>
      <ChapterStepper client:visible lang={lang} />
    </SectionBlock>

    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .landing-title {
    margin-top: var(--space-md);
    max-width: 18ch;
  }

  .landing-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-md);
    max-width: 68ch;
    color: var(--color-text-muted);
  }

  .section-heading {
    margin-bottom: var(--space-md);
  }

  .prereq-list {
    padding-left: var(--space-lg);
  }

  .prereq-list li {
    margin-bottom: var(--space-xs);
  }
</style>
