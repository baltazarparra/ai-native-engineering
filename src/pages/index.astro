---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card/Card.astro';
import { getSessions } from '../data/sessions';
import { TRACKABLE_CHAPTERS, getChapterHref } from '../data/chapters';
import { HARNESS_CHAPTERS, getHarnessChapterHref } from '../data/harness-chapters';
import { getPublishedPosts } from '../lib/blog';
import {
  getBlogHref,
  getHomeAlternateLinks,
  getProjectHref,
  getSessionHref,
  ui,
} from '../lib/i18n';
import { siteLinks } from '../lib/siteLinks';

const lang = 'pt-BR';
const t = ui[lang];

const sortedSessions = getSessions(lang);
const harnessBlocks = HARNESS_CHAPTERS.slice(0, 4);
const projectChapters = TRACKABLE_CHAPTERS;
const latestPosts = (await getPublishedPosts(lang)).slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString(t.dateLocale, { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="AI-Native Engineers"
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero" aria-label="Apresentação">
    <div class="container">
      <p class="kicker">Currículo aberto · Engenharia AI-Native</p>
      <h1 class="hero__title">Engenharia AI-Native</h1>
      <p class="hero__lede">
        Trabalhar com IA não é usar uma ferramenta a mais — é projetar o sistema inteiro em que os
        agentes trabalham. Este site ensina esse ofício em linguagem direta.
      </p>
      <p class="hero__tagline">
        para devs, QA, PM, designers, recrutadores e fundadores — sem precisar ser sênior
      </p>
    </div>
  </section>

  <!-- ═══════════ MANIFESTO ═══════════ -->
  <section class="manifesto section" aria-label="Manifesto">
    <div class="container">
      <p class="kicker kicker--light">O que muda</p>
      <p class="manifesto__text">
        O código deixa de ser o artefato central. O artefato central passa a ser o
        <strong>sistema</strong>: especificações, agentes, contexto, validação e responsabilidade.
      </p>
    </div>
  </section>

  <!-- ═══════════ PRIMER ═══════════ -->
  <section class="primer section" id="fundamentos">
    <div class="container">
      <header class="section-head">
        <p class="kicker">Comece aqui</p>
        <h2 class="section-head__title">O básico, sem jargão</h2>
      </header>

      <div class="primer__blocks">
        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">01</span>
          <h3 class="pblock__title">AI-Native Engineer</h3>
          <p>
            É quem projeta o sistema em que os agentes trabalham: especificação, contexto, validação
            e responsabilidade. Não é "dev que usa Copilot" — é uma mudança de papel, de escrever
            código para arquitetar a produção dele.
          </p>
        </article>

        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">02</span>
          <h3 class="pblock__title">Agente de IA</h3>
          <p>
            É um programa que persegue um objetivo em ciclos: observa o ambiente, planeja, age com
            ferramentas, verifica o resultado e repete. Diferente de um chat que só responde, o
            agente executa — edita arquivos, roda testes, navega.
          </p>
        </article>

        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">03</span>
          <h3 class="pblock__title">Agente de código</h3>
          <p>
            É o agente especializado em software. Lê seu repositório, propõe mudanças, abre arquivos,
            roda comandos e itera até a tarefa passar na validação. Ferramentas como Claude Code,
            Cursor e Windsurf são exemplos do padrão.
          </p>
        </article>

        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">04</span>
          <h3 class="pblock__title">SDD — Spec-Driven Development</h3>
          <p>
            É o método de trabalhar: a especificação vira o artefato principal. O agente implementa a
            partir dela; os testes validam o comportamento dela; o código vira resultado, não fonte
            da verdade.
          </p>
        </article>

        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">05</span>
          <h3 class="pblock__title">Harness Engineering</h3>
          <p>
            É a disciplina de projetar tudo o que envolve o modelo: instruções, ferramentas, memória,
            verificações e limites. É o "chassi" onde o agente roda — e é ele que determina a
            qualidade do que sai.
          </p>
        </article>

        <article class="pblock">
          <span class="pblock__numeral" aria-hidden="true">06</span>
          <h3 class="pblock__title">Por que importa</h3>
          <p>
            Porque a alavanca mudou de mãos. Um engenheiro com um bom harness coordena o que antes
            era um time inteiro. Quem não projeta o sistema vira gargalo dele.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════ SESSÕES ═══════════ -->
  <section class="sessions section" id="sessoes">
    <div class="container">
      <header class="section-head">
        <p class="kicker">Currículo</p>
        <h2 class="section-head__title">O currículo em três sessões</h2>
      </header>

      <div class="sessions__grid">
        {
          sortedSessions.map((session, i) => {
            const href = getSessionHref(lang, session.slug);
            const numeral = String(i + 1).padStart(2, '0');
            const meta = `${session.readingTime} min · ${t.levels[session.level]}`;

            return session.order === 3 ? (
              <a href={href} class="feature-card">
                <div class="feature-card__head">
                  <span class="feature-card__numeral" aria-hidden="true">
                    {numeral}
                  </span>
                  <span class="feature-card__meta">{meta}</span>
                </div>
                <h3 class="feature-card__title">{session.title}</h3>
                <p class="feature-card__summary">{session.summary}</p>
                <span class="feature-card__arrow" aria-hidden="true">
                  →
                </span>
              </a>
            ) : (
              <Card href={href} index={numeral} title={session.title}>
                <Fragment slot="meta">{meta}</Fragment>
                <p>{session.summary}</p>
              </Card>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ═══════════ HARNESS ═══════════ -->
  <section class="harness section">
    <div class="container">
      <header class="section-head">
        <p class="kicker">O sistema completo</p>
        <h2 class="section-head__title">Harness Engineering: o sistema completo</h2>
        <p class="section-head__lede">
          Como modelos de IA viram engenheiros autônomos confiáveis — e o que muda para times,
          produtos e carreiras.
        </p>
      </header>

      <div class="harness__grid">
        {
          harnessBlocks.map((chapter) => (
            <article class="hblock">
              <h3>{chapter.title[lang]}</h3>
              <p>{chapter.description[lang]}</p>
              <a class="text-link" href={getHarnessChapterHref(lang, chapter.id)}>
                {chapter.shortLabel[lang]} →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════ BLOG ═══════════ -->
  <section class="section home-blog" id="blog">
    <div class="container">
      <header class="section-head">
        <p class="kicker">Blog</p>
        <h2 class="section-head__title">Ensaios do campo</h2>
      </header>

      <div class="linkrows">
        {
          latestPosts.map((post) => (
            <a class="linkrow" href={getBlogHref(lang, post.data.slug)}>
              <span class="linkrow__title">{post.data.title}</span>
              <span class="linkrow__meta">
                {post.data.author} · {formatDate(post.data.publishedAt)}
              </span>
            </a>
          ))
        }
      </div>
      <p class="section-more">
        <a class="text-link" href={getBlogHref(lang)}>{t.blog.homeCta} →</a>
      </p>
    </div>
  </section>

  <!-- ═══════════ PROJETO ═══════════ -->
  <section class="section home-project" id="projeto">
    <div class="container">
      <header class="section-head">
        <p class="kicker">Projeto</p>
        <h2 class="section-head__title">{t.project.heading}</h2>
      </header>

      <div class="linkrows">
        <a class="linkrow" href={getProjectHref(lang)}>
          <span class="linkrow__title">{t.project.title}</span>
          <span class="linkrow__meta">{t.project.readingTime}</span>
        </a>
        {
          projectChapters.map((chapter) => (
            <a class="linkrow" href={getChapterHref(chapter.number, lang)}>
              <span class="linkrow__title">{chapter.title[lang]}</span>
              <span class="linkrow__meta">{t.chapters.chapterLabel(chapter.number)}</span>
            </a>
          ))
        }
        <a class="linkrow" href={siteLinks.repository}>
          <span class="linkrow__title">Código-fonte no GitHub</span>
          <span class="linkrow__meta">repositório aberto</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    padding-block: var(--space-4xl) var(--space-3xl);
  }

  .hero__title {
    font-size: var(--text-display);
    font-weight: var(--weight-extrabold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-block: var(--space-lg) var(--space-xl);
  }

  .hero__lede {
    font-family: var(--font-serif);
    font-size: var(--text-lede);
    line-height: 1.45;
    color: var(--color-text-muted);
    max-width: 36ch;
    text-wrap: balance;
  }

  .hero__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-xl);
  }

  /* ── Manifesto strip ──────────────────────────────────── */
  .manifesto {
    background: var(--color-ink);
    color: var(--color-fg-on-ink);
    padding-block: var(--space-3xl);
  }

  .manifesto__text {
    font-size: var(--text-lede);
    line-height: 1.5;
    max-width: 34ch;
    margin-top: var(--space-lg);
  }

  .manifesto__text strong {
    color: var(--color-fg-on-ink);
  }

  /* ── Section headers ──────────────────────────────────── */
  .section-head {
    border-top: var(--line);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .section-head__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.02em;
    margin-top: var(--space-md);
  }

  .section-head__lede {
    font-size: var(--text-lede);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-top: var(--space-md);
  }

  /* ── Primer ───────────────────────────────────────────── */
  .primer__blocks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: var(--space-2xl);
    row-gap: var(--space-2xl);
  }

  .pblock {
    border-top: 2px solid var(--color-ink);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .pblock__numeral {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .pblock__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    margin-block: var(--space-sm) var(--space-md);
  }

  .pblock p {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* ── Sessions ─────────────────────────────────────────── */
  .sessions__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    align-items: stretch;
  }

  .feature-card {
    grid-column: 1 / -1;
    display: block;
    background: var(--color-ink);
    color: var(--color-fg-on-ink);
    padding: var(--space-2xl);
    text-decoration: none;
    position: relative;
    transition: background var(--motion-fast) var(--ease-standard);
  }

  .feature-card:hover {
    background: var(--color-accent);
    color: var(--color-fg-on-accent);
  }

  .feature-card:hover .feature-card__meta,
  .feature-card:hover .feature-card__summary {
    color: var(--color-fg-on-accent);
  }

  .feature-card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xl);
  }

  .feature-card__numeral {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .feature-card__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--color-fg-on-ink) 60%, transparent);
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .feature-card__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-extrabold);
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: var(--space-md);
    max-width: 24ch;
  }

  .feature-card__summary {
    font-size: var(--text-base);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-fg-on-ink) 75%, transparent);
    max-width: 58ch;
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .feature-card__arrow {
    position: absolute;
    right: var(--space-2xl);
    bottom: var(--space-2xl);
    font-size: var(--text-2xl);
    line-height: 1;
  }

  /* ── Harness ──────────────────────────────────────────── */
  .harness__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-2xl);
    row-gap: var(--space-2xl);
  }

  .hblock {
    border-top: 2px solid var(--color-ink);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .hblock h3 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-md);
  }

  .hblock p {
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  /* ── Link rows (blog / projeto) ───────────────────────── */
  .linkrows {
    display: flex;
    flex-direction: column;
  }

  .linkrow {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-xl);
    padding-block: var(--space-md);
    border-bottom: var(--line);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--motion-fast) var(--ease-standard);
  }

  .linkrow:first-child {
    border-top: var(--line);
  }

  .linkrow:hover {
    background: var(--color-surface-alt);
  }

  .linkrow__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
  }

  .linkrow__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: right;
    flex-shrink: 0;
  }

  .section-more {
    margin-top: var(--space-xl);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 1023px) {
    .primer__blocks {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-block: var(--space-3xl) var(--space-2xl);
    }

    .primer__blocks,
    .sessions__grid,
    .harness__grid {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding: var(--space-xl);
    }

    .feature-card__arrow {
      right: var(--space-xl);
      bottom: var(--space-xl);
    }

    .linkrow {
      flex-direction: column;
      gap: var(--space-2xs);
    }

    .linkrow__meta {
      text-align: left;
    }
  }
</style>
