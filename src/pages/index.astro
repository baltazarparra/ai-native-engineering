---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Grid from '../components/Grid/Grid.astro';
import Button from '../components/Button/Button.astro';
import Card from '../components/Card/Card.astro';
import Badge from '../components/Badge/Badge.astro';
import Footer from '../components/Footer/Footer.astro';
import Discussion from '../components/Discussion/Discussion.astro';
import HeroStickers from '../components/HeroStickers/HeroStickers';
import HeroGhostCursors from '../components/HeroGhostCursors/HeroGhostCursors';
import HeroCaptureCounter from '../components/HeroCaptureCounter/HeroCaptureCounter';
import HeroCursorTrail from '../components/HeroCursorTrail/HeroCursorTrail';
import { getSessions } from '../data/sessions';
import {
  getHomeAlternateLinks,
  getSessionHref,
  getProjectHref,
  getHarnessHref,
} from '../lib/i18n';

const lang = 'pt-BR';
const sessions = getSessions(lang);

function levelToBadgeVariant(level: string) {
  const map = {
    beginner: 'yellow',
    intermediate: 'blue',
    advanced: 'green',
  } as const;
  return map[level as keyof typeof map] || 'default';
}

function levelToLabel(level: string) {
  const map = {
    beginner: 'iniciante',
    intermediate: 'intermediário',
    advanced: 'avançado',
  } as const;
  return map[level as keyof typeof map] || level;
}
---

<BaseLayout
  title="Engenharia de Software na Era da IA"
  description="Um guia prático para quem quer usar IA de verdade no dia a dia de desenvolvimento, sem hype e sem medo."
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <main id="main-content">
    <HeroStickers client:visible lang={lang} />
    <!-- hero -->
    <SectionBlock as="header" padding="xl" maxWidth="lg">
      <div class="hero-layer" data-screen-shake>
        <HeroGhostCursors client:visible />
        <HeroCursorTrail client:visible />
        <div class="hero-content">
          <span class="hero-badge-row">
            <Badge variant="green">100% gratuito e open source</Badge>
            <HeroCaptureCounter client:visible lang={lang} />
          </span>
          <h1 class="hero-title">Engenharia de Software na Era da IA</h1>
          <p class="hero-tagline">
            Um guia prático para quem quer usar IA de verdade no dia a dia de
            desenvolvimento, sem hype e sem medo.
          </p>
          <Button href={getSessionHref(lang, sessions[0].slug)} size="lg">
            Iniciar estudos
          </Button>
        </div>
      </div>
    </SectionBlock>

    <!-- session cards -->
    <SectionBlock padding="lg" id="sessoes">
      <h2>Aulas</h2>
      <Grid columns={3} gap="lg" align="stretch">
        {
          sessions.map((session) => (
            <Card
              title={session.title}
              href={getSessionHref(lang, session.slug)}
              accent={session.accent}
            >
              <Fragment slot="meta">
                <Badge variant={levelToBadgeVariant(session.level)} size="sm">
                  {levelToLabel(session.level)}
                </Badge>
                <Badge size="sm">{session.readingTime} min</Badge>
              </Fragment>
              <p>{session.summary}</p>
              <Fragment slot="footer">
                <span class="session-order">Aula {session.order}</span>
              </Fragment>
            </Card>
          ))
        }
      </Grid>
    </SectionBlock>

    <!-- projeto prático -->
    <SectionBlock padding="xl" alt>
      <div class="project-cta-block">
        <Badge variant="coral">Novo</Badge>
        <h2>Projeto Prático</h2>
        <p>
          Quando a teoria fizer sentido, coloque em prática: crie um projeto do
          zero com seu agente de código e publique no GitHub Pages.
        </p>
        <Button href={getProjectHref(lang)} size="lg">
          Ir para o projeto prático
        </Button>
      </div>
    </SectionBlock>

    <!-- harness engineering -->
    <SectionBlock padding="xl">
      <div class="harness-cta-block">
        <div>
          <Badge variant="coral">Conceito</Badge>
          <h2>Harness Engineering</h2>
          <p>
            Depois das sessões, aprofunde como contexto, ferramentas, limites e
            validação transformam um modelo em agente confiável. A Sessão 3
            mostra como operar; esta série explica o sistema por trás.
          </p>
        </div>
        <Button href={getHarnessHref(lang)} size="lg">Entender harness</Button>
      </div>
    </SectionBlock>

    <Discussion
      lang={lang}
      slug="home"
      title="Engenharia de Software na Era da IA"
    />

    <!-- footer -->
    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .hero-layer {
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
  }

  .hero-badge-row {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-title {
    margin-top: var(--space-md);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 42ch;
    margin-block: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .session-order {
    font-family: var(--font-heading);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  :global(#sessoes) {
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    :global(#sessoes) {
      margin-bottom: var(--space-3xl);
    }
  }

  .project-cta-block {
    text-align: center;
    max-width: 42ch;
    margin-inline: auto;
  }

  .harness-cta-block {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
    border: var(--border-thick);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-raised);
    box-shadow: var(--shadow-lg);
    padding: var(--space-xl);
  }

  .harness-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .harness-cta-block p {
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 58ch;
  }

  .project-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .project-cta-block p {
    margin-block: var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  h2 + p {
    margin-block: var(--space-md);
  }

  @media (min-width: 768px) {
    .harness-cta-block {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }
</style>
