---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionBlock from '../components/SectionBlock/SectionBlock.astro';
import Grid from '../components/Grid/Grid.astro';
import Button from '../components/Button/Button.astro';
import Card from '../components/Card/Card.astro';
import Badge from '../components/Badge/Badge.astro';
import Footer from '../components/Footer/Footer.astro';
import Discussion from '../components/Discussion/Discussion.astro';
import HeroStickers from '../components/HeroStickers/HeroStickers';
import HeroGhostCursors from '../components/HeroGhostCursors/HeroGhostCursors';
import HeroCaptureCounter from '../components/HeroCaptureCounter/HeroCaptureCounter';
import HeroCursorTrail from '../components/HeroCursorTrail/HeroCursorTrail';
import { getSessions } from '../data/sessions';
import {
  getHomeAlternateLinks,
  getSessionHref,
  getProjectHref,
  getHarnessHref,
  ui,
} from '../lib/i18n';

const lang = 'pt-BR';
const sessions = getSessions(lang);
const project = ui[lang].project;

function levelToBadgeVariant(level: string) {
  const map = {
    beginner: 'yellow',
    intermediate: 'blue',
    advanced: 'green',
  } as const;
  return map[level as keyof typeof map] || 'default';
}

function levelToLabel(level: string) {
  const map = {
    beginner: 'iniciante',
    intermediate: 'intermediário',
    advanced: 'avançado',
  } as const;
  return map[level as keyof typeof map] || level;
}
---

<BaseLayout
  title="AI-Native Engineers"
  description="Guia prático para programar com agentes de código"
  lang={lang}
  alternateLinks={getHomeAlternateLinks()}
>
  <main id="main-content">
    <HeroStickers client:visible lang={lang} />
    <!-- hero -->
    <SectionBlock as="header" padding="md" maxWidth="lg" id="hero">
      <div class="hero-layer" data-screen-shake>
        <HeroGhostCursors client:visible />
        <HeroCursorTrail client:visible />
        <div class="hero-content">
          <span class="hero-badge-row">
            <Badge variant="green">100% gratuito e open source</Badge>
            <HeroCaptureCounter client:visible lang={lang} />
          </span>
          <h1 class="hero-title">AI-Native Engineers</h1>
          <p class="hero-tagline">
            Guia prático para programar com agentes de código
          </p>
        </div>
      </div>
    </SectionBlock>

    <!-- session cards -->
    <SectionBlock padding="lg" id="sessoes">
      <h2>Aulas</h2>
      <p class="sessions-intro">
        Três aulas em sequência: do vibe coding às ferramentas de IA e ao fluxo
        profissional com agentes de código.
      </p>
      <Grid columns={3} gap="lg" align="stretch">
        {
          sessions.map((session) => (
            <Card
              title={session.title}
              href={getSessionHref(lang, session.slug)}
              accent={session.accent}
            >
              <Fragment slot="meta">
                <Badge variant={levelToBadgeVariant(session.level)} size="sm">
                  {levelToLabel(session.level)}
                </Badge>
                <Badge size="sm">{session.readingTime} min</Badge>
              </Fragment>
              <p>{session.summary}</p>
              <Fragment slot="footer">
                <div class="card-footer-row">
                  <span class="session-order">Aula {session.order}</span>
                  <span class="card-cta">
                    Acessar aula
                    <span class="card-cta-arrow" aria-hidden="true">
                      →
                    </span>
                  </span>
                </div>
              </Fragment>
            </Card>
          ))
        }
      </Grid>
    </SectionBlock>

    <!-- harness engineering -->
    <SectionBlock padding="xl" alt>
      <div class="harness-cta-block">
        <div>
          <Badge variant="coral">Aprofundamento</Badge>
          <h2>Harness Engineering</h2>
          <p>
            Entenda como prompts, ferramentas, contexto, limites e validações
            transformam um modelo em um agente mais confiável.
          </p>
        </div>
        <Button href={getHarnessHref(lang)} size="lg">Entender harness</Button>
      </div>
    </SectionBlock>

    <!-- projeto prático -->
    <SectionBlock padding="xl" alt>
      <div class="project-cta-block">
        <Badge variant="coral">Novo</Badge>
        <h2>{project.title}</h2>
        <p>{project.homeDesc}</p>
        <Button href={getProjectHref(lang)} size="lg">
          {project.homeCta}
        </Button>
      </div>
    </SectionBlock>

    <Discussion lang={lang} slug="home" title="AI-Native Engineers" />

    <!-- footer -->
    <Footer lang={lang} />
  </main>
</BaseLayout>

<style>
  .hero-layer {
    position: relative;
    z-index: 1;
    isolation: isolate;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    isolation: isolate;
  }

  .hero-badge-row {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-title {
    margin-top: var(--space-md);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 42ch;
    margin-block: var(--space-lg);
    line-height: var(--leading-relaxed);
  }

  .sessions-intro {
    max-width: 60ch;
    margin-block: var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .session-order {
    font-family: var(--font-heading);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .card-footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-heading);
    font-weight: var(--weight-bold);
    font-size: var(--text-sm);
    color: var(--color-primary);
  }

  .card-cta-arrow {
    transition: transform var(--transition-fast);
  }

  :global(.linkable):hover .card-cta-arrow {
    transform: translateX(4px);
  }

  :global(#hero) {
    padding-bottom: var(--space-lg);
  }

  :global(#sessoes) {
    padding-top: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 1024px) {
    :global(#hero) {
      padding-bottom: var(--space-xl);
    }

    :global(#sessoes) {
      padding-top: var(--space-xl);
      margin-bottom: var(--space-3xl);
    }
  }

  .project-cta-block {
    text-align: center;
    max-width: 42ch;
    margin-inline: auto;
  }

  .harness-cta-block {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
    border: var(--border-thick);
    border-radius: var(--radius-md);
    background-color: var(--color-surface-raised);
    box-shadow: var(--shadow-lg);
    padding: var(--space-xl);
  }

  .harness-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .harness-cta-block p {
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 58ch;
  }

  .project-cta-block h2 {
    margin-top: var(--space-sm);
  }

  .project-cta-block p {
    margin-block: var(--space-md) var(--space-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  h2 + p {
    margin-block: var(--space-md);
  }

  @media (min-width: 768px) {
    .harness-cta-block {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }
</style>
