---
import styles from './NextSessionCTA.module.css';
import Button from '../Button/Button.astro';
import type { Lang } from '../../lib/i18n';
import { getProjectHref, getSessionHref, ui } from '../../lib/i18n';

interface Props {
  lang?: Lang;
  nextTitle?: string;
  nextSlug?: string;
  nextHeroLabel?: string;
  isLast?: boolean;
}

const {
  lang = 'pt-BR',
  nextTitle,
  nextSlug,
  nextHeroLabel,
  isLast = false,
} = Astro.props;
const labels = ui[lang].nextSession;
---

<div class={styles.cta}>
  {
    isLast ? (
      <>
        <span class={styles.label}>{labels.lastLabel}</span>
        <p class={styles.title}>{labels.lastTitle}</p>
        <Button href={getProjectHref(lang)} size="lg">
          {labels.home}
        </Button>
      </>
    ) : (
      <>
        <span class={styles.label}>{labels.label}</span>
        {nextHeroLabel && <span class={styles.heroLabel}>{nextHeroLabel}</span>}
        <p class={styles.title}>{nextTitle}</p>
        <Button href={getSessionHref(lang, nextSlug || '')} size="lg">
          {labels.continue}
        </Button>
      </>
    )
  }
</div>
