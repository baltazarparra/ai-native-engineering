---
import GitHubIcon from '../Icons/GitHubIcon.astro';
import styles from './Footer.module.css';
import type { Lang } from '../../lib/i18n';
import { getBlogHref, ui } from '../../lib/i18n';
import { siteLinks } from '../../lib/siteLinks';

interface Props {
  lang?: Lang;
}

const { lang = 'pt-BR' } = Astro.props;
const blogHref = getBlogHref(lang);
---

<!-- Phase 6 discovery: footer + home entry points to /blog/ (BLOG-ROADMAP) -->
<footer class={styles.footer}>
  <div class={styles.inner}>
    <a
      class={styles.tagline}
      href={siteLinks.baltz}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={ui[lang].footer.personalSite}
    >
      {ui[lang].footer.tagline}
    </a>
|
    <a
      class={styles.tagline}
      href={siteLinks.pachi}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={ui[lang].footer.personalSitePachi}
    >
      {ui[lang].footer.taglinePachi}
    </a>

    <a class={styles.navLink} href={blogHref}>
      {ui[lang].footer.blogLink}
    </a>
    <div class={styles.meta}>
      <span class={styles.copy}>AI-Native Engineers</span>
      <a
        class={styles.socialLink}
        href={siteLinks.repository}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={ui[lang].footer.repositoryLink}
      >
        <GitHubIcon class={styles.icon} />
      </a>
    </div>
  </div>
</footer>
