---
import ThemeToggle from '../ThemeToggle/ThemeToggle.tsx';
import FlagIcon from '../Icons/FlagIcon.astro';
import GitHubIcon from '../Icons/GitHubIcon.astro';
import type { AlternateLink, Lang } from '../../lib/i18n';
import { getHomeHref, languages, supportedLangs, ui } from '../../lib/i18n';
import { siteLinks } from '../../lib/siteLinks';
import styles from './SiteHeader.module.css';

interface Props {
  lang: Lang;
  alternateLinks?: AlternateLink[];
}

const { lang, alternateLinks = [] } = Astro.props;
const labels = ui[lang];

function getHref(targetLang: Lang) {
  return (
    alternateLinks.find((link) => link.lang === targetLang)?.href ||
    getHomeHref(targetLang)
  );
}
---

<header
  class={styles.header}
  transition:persist
  data-site-header
  data-active-class={styles.active}
  data-current-language-label={labels.currentLanguage}
>
  <div class={styles.inner}>
    <div class={styles.brandGroup}>
      <a class={styles.brand} href={getHomeHref(lang)}>AI-Native Engineers</a>
      <a
        class={styles.iconLink}
        href={siteLinks.repository}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={labels.repositoryLink}
      >
        <GitHubIcon class={styles.icon} />
      </a>
    </div>
    <div class={styles.actions}>
      <ThemeToggle client:idle lang={lang} />
      <nav class={styles.langNav} aria-label={labels.languageNav}>
        {
          supportedLangs.map((targetLang) => {
            const isCurrent = targetLang === lang;
            return (
              <a
                class:list={[styles.langLink, isCurrent && styles.active]}
                href={getHref(targetLang)}
                data-language-choice={targetLang}
                data-lang-label={languages[targetLang].label}
                aria-current={isCurrent ? 'true' : undefined}
                aria-label={
                  isCurrent
                    ? `${languages[targetLang].label}: ${labels.currentLanguage}`
                    : languages[targetLang].label
                }
              >
                <FlagIcon
                  country={languages[targetLang].flag}
                  class={styles.flagIcon}
                />
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const htmlLangToChoice = { 'pt-BR': 'pt-BR', pt: 'pt-BR', en: 'en' };

    function resolveCurrentLang(doc) {
      const htmlLang = doc.documentElement.getAttribute('lang') || '';
      return htmlLangToChoice[htmlLang] || htmlLang;
    }

    function syncLanguageLinks() {
      const header = document.querySelector('[data-site-header]');
      // On astro:after-swap the document has already been replaced, so read the
      // live (new) document directly. event.newDocument only exists on
      // astro:before-swap and would be undefined here, which left the persisted
      // header pointing at the previous page's language hrefs.
      const doc = document;
      if (!header) return;

      const alternates = {};
      doc
        .querySelectorAll('link[rel="alternate"][hreflang]')
        .forEach(function (link) {
          const hreflang = link.getAttribute('hreflang');
          if (hreflang && hreflang !== 'x-default') {
            alternates[hreflang] = link.getAttribute('href');
          }
        });

      const currentLang = resolveCurrentLang(doc);
      const activeClass = header.getAttribute('data-active-class');
      const currentLanguageLabel =
        header.getAttribute('data-current-language-label') || '';

      header
        .querySelectorAll('[data-language-choice]')
        .forEach(function (link) {
          const choice = link.getAttribute('data-language-choice');
          if (choice && alternates[choice]) {
            link.setAttribute('href', alternates[choice]);
          }

          const isCurrent = choice === currentLang;
          if (activeClass) {
            link.classList.toggle(activeClass, isCurrent);
          }
          if (isCurrent) {
            link.setAttribute('aria-current', 'true');
            const langLabel =
              link.getAttribute('data-lang-label') || choice || '';
            link.setAttribute(
              'aria-label',
              currentLanguageLabel
                ? langLabel + ': ' + currentLanguageLabel
                : langLabel,
            );
          } else {
            link.removeAttribute('aria-current');
            link.setAttribute(
              'aria-label',
              link.getAttribute('data-lang-label') || choice || '',
            );
          }
        });
    }

    if (!window.__aiNativeLanguageLinkSync) {
      window.__aiNativeLanguageLinkSync = true;
      document.addEventListener('astro:after-swap', syncLanguageLinks);
    }
  })();
</script>
