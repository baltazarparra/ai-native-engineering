---
import FlagIcon from '../Icons/FlagIcon.astro';
import GitHubIcon from '../Icons/GitHubIcon.astro';
import type { AlternateLink, Lang } from '../../lib/i18n';
import { getHomeHref, languages, supportedLangs, ui } from '../../lib/i18n';
import { siteLinks } from '../../lib/siteLinks';
import styles from './SiteHeader.module.css';

interface Props {
  lang: Lang;
  alternateLinks?: AlternateLink[];
}

const { lang, alternateLinks = [] } = Astro.props;
const labels = ui[lang];

function getHref(targetLang: Lang) {
  return (
    alternateLinks.find((link) => link.lang === targetLang)?.href ||
    getHomeHref(targetLang)
  );
}
---

<header class={styles.header}>
  <div class={styles.inner}>
    <div class={styles.brandGroup}>
      <a class={styles.brand} href={getHomeHref(lang)}>AI-Native Engineering</a>
      <a
        class={styles.iconLink}
        href={siteLinks.repository}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={labels.repositoryLink}
      >
        <GitHubIcon class={styles.icon} />
      </a>
    </div>
    <div class={styles.actions}>
      <nav class={styles.langNav} aria-label={labels.languageNav}>
        {
          supportedLangs.map((targetLang) => {
            const isCurrent = targetLang === lang;
            return (
              <a
                class:list={[styles.langLink, isCurrent && styles.active]}
                href={getHref(targetLang)}
                data-language-choice={targetLang}
                aria-current={isCurrent ? 'true' : undefined}
                aria-label={
                  isCurrent
                    ? `${languages[targetLang].label}: ${labels.currentLanguage}`
                    : languages[targetLang].label
                }
              >
                <FlagIcon
                  country={languages[targetLang].flag}
                  class={styles.flagIcon}
                />
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>
