---
/**
 * Render one Notion block (lists handled by NotionBlocks segmenting).
 */
import NotionBlocks from './NotionBlocks.astro';
import NotionImage from './NotionImage.astro';
import type { BlogBlockWithChildren } from '../../lib/notion';
import { highlightNotionCode } from '../../lib/blog-highlight';
import { isAllCodeRichText, notionRichHtml, notionRichPlain } from '../../lib/notion-rich-text';
import styles from './NotionBlocks.module.css';

interface Props {
  block: BlogBlockWithChildren;
}

const { block } = Astro.props;

function imageUrl(bl: Extract<BlogBlockWithChildren, { type: 'image' }>): string | null {
  const img = bl.image;
  if (img.type === 'external') return img.external.url;
  if (img.type === 'file') return img.file.url;
  return null;
}

let highlightedCodeHtml = '';
if (block.type === 'code') {
  highlightedCodeHtml = await highlightNotionCode(
    notionRichPlain(block.code.rich_text),
    block.code.language ?? undefined,
  );
} else if (block.type === 'paragraph' && isAllCodeRichText(block.paragraph.rich_text)) {
  highlightedCodeHtml = await highlightNotionCode(notionRichPlain(block.paragraph.rich_text));
}
---

{
  block.type === 'paragraph' ? (
    notionRichPlain(block.paragraph.rich_text).trim() ? (
      isAllCodeRichText(block.paragraph.rich_text) ? (
        <div class:list={[styles.pre, styles.shikiWrap]} set:html={highlightedCodeHtml} />
      ) : (
        <p class:list={[styles.paragraph]} set:html={notionRichHtml(block.paragraph.rich_text)} />
      )
    ) : null
  ) : block.type === 'heading_1' ? (
    notionRichPlain(block.heading_1.rich_text).trim() ? (
      <h2 class:list={[styles.heading1]}>{notionRichPlain(block.heading_1.rich_text)}</h2>
    ) : null
  ) : block.type === 'heading_2' ? (
    notionRichPlain(block.heading_2.rich_text).trim() ? (
      <h3 class:list={[styles.heading2]}>{notionRichPlain(block.heading_2.rich_text)}</h3>
    ) : null
  ) : block.type === 'heading_3' ? (
    notionRichPlain(block.heading_3.rich_text).trim() ? (
      <h4 class:list={[styles.heading3]}>{notionRichPlain(block.heading_3.rich_text)}</h4>
    ) : null
  ) : block.type === 'quote' ? (
    <blockquote class:list={[styles.quote]}>
      {
        notionRichPlain(block.quote.rich_text).trim() ? (
          <p class:list={[styles.paragraph]}>{notionRichPlain(block.quote.rich_text)}</p>
        ) : null
      }
      {
        block.children?.length ? (
          <div class:list={[styles.quoteNested]}>
            <NotionBlocks blocks={block.children} />
          </div>
        ) : null
      }
    </blockquote>
  ) : block.type === 'code' ? (
    <div class:list={[styles.pre, styles.shikiWrap]} set:html={highlightedCodeHtml} />
  ) : block.type === 'image' ? (
    imageUrl(block) ? (
      <figure class:list={[styles.figure]}>
        <NotionImage
          class:list={[styles.img]}
          src={imageUrl(block)!}
          alt={notionRichPlain(block.image.caption).trim() || ''}
          width={920}
          height={518}
          loading="lazy"
          decoding="async"
        />
        {
          notionRichPlain(block.image.caption).trim() ? (
            <figcaption class:list={[styles.figcaption]}>
              {notionRichPlain(block.image.caption)}
            </figcaption>
          ) : null
        }
      </figure>
    ) : (
      <p class:list={[styles.unsupported]} data-notion-kind="image">
        <span>image</span> — URL não disponível.
      </p>
    )
  ) : block.type === 'divider' ? (
    <hr class:list={[styles.divider]} />
  ) : (
    <p class:list={[styles.unsupported]} data-notion-kind={block.type}>
      Bloco não suportado nesta versão (<span>{block.type}</span>).
    </p>
  )
}
