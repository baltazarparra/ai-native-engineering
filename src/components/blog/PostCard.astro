---
/**
 * Blog listing card — local MDX posts.
 */
import { withBase } from '../../lib/i18n';
import styles from './PostCard.module.css';

interface Props {
  title: string;
  slug: string;
  summary: string;
  publishedAt: Date;
  cover?: string;
  tags?: string[];
}

const { title, slug, summary, publishedAt, cover, tags = [] } = Astro.props;

const href = withBase(`blog/${encodeURIComponent(slug)}`);

const coverSrc = cover
  ? cover.startsWith('http://') || cover.startsWith('https://')
    ? cover
    : withBase(cover.replace(/^\//, ''))
  : null;

const publishedLabel = publishedAt.toLocaleDateString('pt-BR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a href={href} class={styles.root}>
  {
    coverSrc ? (
      <div class={styles.coverWrap}>
        <img
          src={coverSrc}
          alt={title}
          class={styles.coverImg}
          width={800}
          height={450}
          loading="lazy"
          decoding="async"
        />
      </div>
    ) : null
  }
  <div class={styles.body}>
    <span class={styles.title}>{title}</span>
    <div class={styles.metaRow}>
      <time datetime={publishedAt.toISOString()}>{publishedLabel}</time>
    </div>
    {
      tags.length > 0 ? (
        <ul class={styles.tagList} aria-label="Tags">
          {tags.map((tag) => (
            <li class={styles.tag}>{tag}</li>
          ))}
        </ul>
      ) : null
    }
    {summary.trim() ? <p class={styles.summary}>{summary}</p> : null}
  </div>
</a>
