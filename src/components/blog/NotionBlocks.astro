---
/**
 * Recursive Notion block tree — MVP (blog-plan Phase B5).
 * Types: import type from notion.ts only (no runtime notion / client:*).
 */
import NotionBlockPiece from './NotionBlockPiece.astro';
import type { BlogBlockWithChildren } from '../../lib/notion';
import { notionRichHtml, notionRichPlain } from '../../lib/notion-rich-text';
import { segmentListRuns } from './segment-blocks';
import styles from './NotionBlocks.module.css';

interface Props {
  blocks: BlogBlockWithChildren[];
}

const { blocks } = Astro.props;
const segments = segmentListRuns(blocks);
---

<div class:list={[styles.nbRoot]} data-blog-notion-blocks="true">
  {
    segments.map((seg) =>
      seg.kind === 'single' ? (
        <NotionBlockPiece block={seg.block} />
      ) : seg.kind === 'bullets' ? (
        <ul class:list={[styles.list]}>
          {seg.blocks.map((liBlock) =>
            liBlock.type === 'bulleted_list_item' ? (
              <li class:list={[styles.item]}>
                {
                  notionRichPlain(liBlock.bulleted_list_item.rich_text).trim() ? (
                    <p
                      class:list={[styles.paragraph]}
                      set:html={notionRichHtml(liBlock.bulleted_list_item.rich_text)}
                    />
                  ) : null
                }
                {
                  liBlock.children?.length ? (
                    <div class:list={[styles.listNested]}>
                      <Astro.self blocks={liBlock.children} />
                    </div>
                  ) : null
                }
              </li>
            ) : null,
          )}
        </ul>
      ) : (
        <ol class:list={[styles.list]}>
          {seg.blocks.map((liBlock) =>
            liBlock.type === 'numbered_list_item' ? (
              <li class:list={[styles.item]}>
                {
                  notionRichPlain(liBlock.numbered_list_item.rich_text).trim() ? (
                    <p
                      class:list={[styles.paragraph]}
                      set:html={notionRichHtml(liBlock.numbered_list_item.rich_text)}
                    />
                  ) : null
                }
                {
                  liBlock.children?.length ? (
                    <div class:list={[styles.listNested]}>
                      <Astro.self blocks={liBlock.children} />
                    </div>
                  ) : null
                }
              </li>
            ) : null,
          )}
        </ol>
      ),
    )
  }
</div>
