# Blog (build-time Notion) — copy to `.env` and fill with real values. Never commit `.env`.

# Integration token from a Notion integration with access to the posts database:
# https://www.notion.so/my-integrations
NOTION_TOKEN=

# UUID of the blog posts database from its URL (hyphens preserved).
# Property contract: Title, Slug, Status (Published | Draft), PublishedAt, Summary, Cover — see docs-blog/blog-plan.md
NOTION_DATABASE_ID=
